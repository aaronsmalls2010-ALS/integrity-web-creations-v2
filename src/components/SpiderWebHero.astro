---
// Full-viewport canvas spider web animation — metallic silver threads
---

<canvas
  id="spider-canvas"
  style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1;"
></canvas>

<script>
  const canvas = document.getElementById('spider-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;

  let W = 0, H = 0;
  let origin      = { x: 0, y: 0 };
  let spokeAngles: number[] = [];
  let ringDists:   number[] = [];
  let animStart:   number | null = null;
  let cursor       = { x: -9999, y: -9999 };

  const ACTION_LINES = Array.from({ length: 28 }, (_, i) => ({
    angle: (i / 28) * Math.PI * 2,
    len:   60 + (i * 19) % 100,
    w:     0.7 + (i * 0.13) % 1.2,
  }));

  const T = {
    MOUSE_ARRIVE: 0.15,
    BTN_GLOW:     0.85,
    CLICK:        1.05,
    WEB_DONE:     3.60,
  };

  function clamp01(v: number) { return Math.max(0, Math.min(1, v)); }

  function resize() {
    const rect = canvas.parentElement!.getBoundingClientRect();
    W = canvas.width  = rect.width;
    H = canvas.height = rect.height;
    buildWebGeometry();
  }

  function buildWebGeometry() {
    const NS = 22;
    const A0 = Math.PI * 0.489;
    const A1 = Math.PI * 1.112;
    spokeAngles = [];
    for (let i = 0; i < NS; i++) {
      const t = i / (NS - 1);
      spokeAngles.push(A0 + (A1 - A0) * t + Math.sin(i * 6.7 + 2.3) * 0.006);
    }

    const NR    = 16;
    const MAX_R = Math.hypot(W, H) * 1.08;
    ringDists = [];
    for (let r = 0; r < NR; r++) {
      const t = (r + 1) / NR;
      ringDists.push(MAX_R * Math.log(1 + t * (Math.E - 1)) * (1 + Math.sin(r * 3.7) * 0.01));
    }
  }

  function pt(angle: number, dist: number) {
    return { x: origin.x + Math.cos(angle) * dist, y: origin.y + Math.sin(angle) * dist };
  }

  function strand(
    p1: { x: number; y: number },
    p2: { x: number; y: number },
    rgba: string,
    weight: number,
    sag: number
  ) {
    const mx = (p1.x + p2.x) * 0.5, my = (p1.y + p2.y) * 0.5;
    const dx = cursor.x - mx,        dy = cursor.y - my;
    const pull = Math.max(0, 1 - Math.hypot(dx, dy) / 150) * 24;
    ctx.beginPath();
    ctx.moveTo(p1.x, p1.y);
    ctx.quadraticCurveTo(
      mx + dx * pull * 0.04,
      my + dy * pull * 0.04 + (sag || 0),
      p2.x, p2.y
    );
    ctx.strokeStyle = rgba;
    ctx.lineWidth   = weight;
    ctx.lineCap     = 'round';
    ctx.stroke();
  }

  function drawScreenFlash(t: number) {
    if (t <= 0 || t >= 1) return;
    const a = t < 0.25 ? t / 0.25 : 1 - (t - 0.25) / 0.75;
    ctx.save();
    ctx.globalAlpha = a * 0.2;
    ctx.fillStyle   = '#c0cad8';
    ctx.fillRect(0, 0, W, H);
    ctx.restore();
  }

  function drawActionLines(t: number) {
    if (t <= 0 || t >= 1) return;
    const fade   = Math.max(0, 1 - t / 0.55);
    const extend = Math.min(t / 0.14, 1);
    ACTION_LINES.forEach(l => {
      const r1 = 50 * extend, r2 = (50 + l.len) * extend;
      ctx.beginPath();
      ctx.moveTo(origin.x + Math.cos(l.angle) * r1, origin.y + Math.sin(l.angle) * r1);
      ctx.lineTo(origin.x + Math.cos(l.angle) * r2, origin.y + Math.sin(l.angle) * r2);
      ctx.strokeStyle = `rgba(192,202,216,${fade * 0.3})`;
      ctx.lineWidth   = l.w + 2;
      ctx.lineCap     = 'round';
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(origin.x + Math.cos(l.angle) * r1, origin.y + Math.sin(l.angle) * r1);
      ctx.lineTo(origin.x + Math.cos(l.angle) * r2, origin.y + Math.sin(l.angle) * r2);
      ctx.strokeStyle = `rgba(136,153,170,${fade * 0.6})`;
      ctx.lineWidth   = l.w;
      ctx.stroke();
    });
  }

  function drawOriginGlow(t: number) {
    if (t <= 0) return;
    [0, 0.13, 0.26].forEach(off => {
      const p = clamp01((t - off) / 0.54);
      if (p <= 0) return;
      ctx.beginPath();
      ctx.arc(origin.x, origin.y, 100 * p, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(192,202,216,${(1 - p) * 0.35})`;
      ctx.lineWidth   = (1 - p) * 3;
      ctx.stroke();
    });
    const op = Math.min(1, t * 3) * 0.6;
    const g  = ctx.createRadialGradient(origin.x, origin.y, 0, origin.x, origin.y, 36);
    g.addColorStop(0,   `rgba(224,231,238,${op * 0.7})`);
    g.addColorStop(0.4, `rgba(136,153,170,${op * 0.3})`);
    g.addColorStop(1,   'rgba(136,153,170,0)');
    ctx.beginPath();
    ctx.arc(origin.x, origin.y, 36, 0, Math.PI * 2);
    ctx.fillStyle = g;
    ctx.fill();
    ctx.beginPath();
    ctx.arc(origin.x, origin.y, 3.5, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(224,231,238,${op})`;
    ctx.fill();
  }

  function drawWeb(t: number) {
    const ease      = 1 - Math.pow(1 - t, 2.2);
    const maxR      = ringDists[ringDists.length - 1];
    const frontierR = maxR * ease;
    if (frontierR < 2) return;

    const SOFT = maxR * 0.06;

    spokeAngles.forEach(angle => {
      const visR = Math.min(frontierR, maxR);
      if (visR < 2) return;
      const endPt = pt(angle, visR);
      strand(origin, endPt, 'rgba(192,202,216,0.08)', 3.0, 0);
      strand(origin, endPt, 'rgba(136,153,170,0.25)', 1.2, 0);
    });

    if (frontierR < maxR * 0.99) {
      spokeAngles.forEach(angle => {
        const tip = pt(angle, Math.min(frontierR, maxR));
        const tg  = ctx.createRadialGradient(tip.x, tip.y, 0, tip.x, tip.y, 8);
        tg.addColorStop(0, 'rgba(224,231,238,0.5)');
        tg.addColorStop(1, 'rgba(136,153,170,0)');
        ctx.beginPath();
        ctx.arc(tip.x, tip.y, 8, 0, Math.PI * 2);
        ctx.fillStyle = tg;
        ctx.fill();
      });
    }

    ringDists.forEach((dist, ri) => {
      if (dist > frontierR) return;
      const fadeIn = clamp01((frontierR - dist) / SOFT);
      if (fadeIn <= 0) return;

      const df  = 1 - ri / ringDists.length;
      const opG = (0.04 + df * 0.08) * fadeIn;
      const opC = (0.10 + df * 0.20) * fadeIn;
      const wG  = 2.4 - df * 0.4;
      const wC  = 1.0 - df * 0.1;

      for (let s = 0; s < spokeAngles.length - 1; s++) {
        const p1  = pt(spokeAngles[s],     dist);
        const p2  = pt(spokeAngles[s + 1], dist);
        const sag = Math.abs(p2.x - p1.x) * 0.038 + Math.abs(p2.y - p1.y) * 0.010;
        strand(p1, p2, `rgba(192,202,216,${opG})`, wG, sag * 1.4);
        strand(p1, p2, `rgba(136,153,170,${opC})`, wC, sag);
      }

      if (fadeIn > 0.55) {
        spokeAngles.forEach(angle => {
          const n = pt(angle, dist);
          if (n.x < -30 || n.x > W + 30 || n.y < -30 || n.y > H + 30) return;
          ctx.beginPath();
          ctx.arc(n.x, n.y, 1.5, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(192,202,216,${0.35 * df * fadeIn})`;
          ctx.fill();
        });
      }
    });
  }

  function render(ts: number) {
    if (!animStart) animStart = ts;
    const e = (ts - animStart) / 1000;

    ctx.clearRect(0, 0, W, H);

    drawScreenFlash(clamp01((e - T.CLICK) / 0.40));
    drawOriginGlow( clamp01((e - T.CLICK) / 0.85));
    drawActionLines(clamp01((e - T.CLICK) / 0.56));

    const webT = clamp01((e - T.CLICK) / (T.WEB_DONE - T.CLICK));
    if (webT > 0) drawWeb(webT);

    requestAnimationFrame(render);
  }

  function init() {
    resize();
    origin = { x: W - 18, y: 41 };
    buildWebGeometry();

    setTimeout(() => {
      origin = { x: W * 0.85, y: H * 0.12 };
      buildWebGeometry();
    }, T.MOUSE_ARRIVE * 1000);

    requestAnimationFrame(render);
  }

  window.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    cursor.x = e.clientX - rect.left;
    cursor.y = e.clientY - rect.top;
  });
  window.addEventListener('resize', () => resize(), { passive: true });

  init();
</script>
