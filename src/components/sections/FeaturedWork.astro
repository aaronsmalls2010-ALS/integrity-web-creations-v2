---
const work = [
  {
    name:     'The Friendship Baptist Church',
    url:      'https://thefriendshipbaptist.com',
    category: 'Church',
    location: 'Beaufort, SC',
    image:    '/images/work-friendship-baptist.jpg',
    hasImage: true,
  },
  {
    name:     'Arena Football Players Union',
    url:      'https://aflpu.org',
    category: 'Professional Sports Union',
    location: 'Atlanta, GA',
    image:    '/images/work-aflpu.jpg',
    hasImage: true,
  },
  {
    name:     'Nora',
    url:      null,
    category: 'Travel Agency',
    location: 'United States',
    image:    '/images/work-nora.jpg',
    hasImage: true,
  },
  {
    name:     'Hair Essence',
    url:      'https://hair-essence.vercel.app',
    category: 'Natural Hair Studio',
    location: 'Lexington, SC',
    image:    '/images/work-hair-essence.jpg',
    hasImage: true,
  },
  {
    name:     'Epps Medical',
    url:      null,
    category: 'Medical Practice',
    location: 'Savannah, GA',
    image:    null,
    hasImage: false,
  },
  {
    name:     'The Beaufort Marina',
    url:      null,
    category: 'Marina',
    location: 'Beaufort, SC',
    image:    null,
    hasImage: false,
  },
];
---

<div class="section-line"></div>

<section id="work" class="bg-bg py-28">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-16 reveal-up">
      <p class="text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 mb-4">
        Portfolio
      </p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-5">
        Built for <span class="text-metallic">Real Businesses</span>
      </h2>
      <p class="text-muted text-base max-w-xl mx-auto leading-relaxed">
        From local churches to professional sports unions &mdash; real sites,
        real results, real businesses you can visit.
      </p>
    </div>

    <!-- Portfolio grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-stagger>
      {work.map((item, i) => (
        <div
          class={`group relative rounded-2xl overflow-hidden border border-white/[0.06] aspect-video bg-card hover:border-cyan/20 transition-all duration-300 reveal-up${work.length % 2 !== 0 && i === work.length - 1 ? ' md:col-span-2 md:aspect-[21/9]' : ''}`}
        >
          {item.hasImage ? (
            <img
              src={item.image!}
              alt={`${item.name} website`}
              class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-full flex flex-col items-center justify-center gap-4 bg-gradient-to-br from-surface to-card">
              <div class="w-16 h-16 rounded-xl bg-white/[0.04] border border-white/[0.06] flex items-center justify-center">
                <i class="fa-solid fa-globe text-steel text-2xl"></i>
              </div>
              <div class="text-center px-4">
                <p class="font-display text-sm font-bold text-white">{item.name}</p>
                <p class="text-steel text-xs mt-1">Screenshot coming soon</p>
              </div>
            </div>
          )}

          {/* Hover overlay */}
          <div class="absolute inset-0 bg-gradient-to-t from-bg/95 via-bg/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-7">
            <span class="text-[10px] font-medium tracking-[0.3em] uppercase text-cyan/60">
              {item.category} &middot; {item.location}
            </span>
            <h3 class="font-display text-lg font-bold text-white mt-1.5">{item.name}</h3>
            {item.url && (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-cyan/70 hover:text-cyan text-sm mt-2 no-underline transition-colors"
              >
                {item.url.replace('https://', '')}
                <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
