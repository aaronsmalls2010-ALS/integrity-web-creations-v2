---
---
<section id="free-audit" class="relative py-32 bg-bg overflow-hidden">

  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/4 w-[500px] h-[500px] rounded-full bg-cyan/[0.015] blur-[100px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">
          Complimentary
        </span>
        <h2 class="reveal-up font-display font-bold text-white mb-6" style="font-size:clamp(28px,3.5vw,48px);">
          Free Website <span class="text-metallic">Audit</span>
        </h2>
        <p class="reveal-up text-muted text-base leading-relaxed mb-6 max-w-lg">
          Not sure where your website stands? We&rsquo;ll review your current site (or online presence) and deliver a detailed report covering:
        </p>
        <ul class="reveal-up space-y-3 text-muted/70 text-sm max-w-lg">
          {['Performance & speed analysis', 'Mobile responsiveness', 'SEO & search visibility', 'Security vulnerabilities', 'Content & design assessment'].map(item => (
            <li class="flex items-center gap-3">
              <span class="w-1 h-1 rounded-full bg-cyan/50 flex-shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
        <p class="reveal-up text-steel/50 text-xs mt-6 tracking-wide">
          No obligation. No pressure. Just clarity on where you stand.
        </p>
      </div>

      <!-- Right: form -->
      <div class="reveal-right">
        <form
          id="audit-form"
          class="glass-card rounded-lg p-8 space-y-5"
        >
          <div>
            <label for="audit-name" class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium block mb-2">Your Name</label>
            <input
              type="text"
              id="audit-name"
              name="name"
              required
              class="w-full bg-bg/50 border border-white/[0.06] text-white text-sm rounded-md px-4 py-3 placeholder:text-steel/30 outline-none focus:border-cyan/30 transition-colors tracking-wide"
              placeholder="Jane Doe"
            />
          </div>
          <div>
            <label for="audit-email" class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium block mb-2">Email</label>
            <input
              type="email"
              id="audit-email"
              name="email"
              required
              class="w-full bg-bg/50 border border-white/[0.06] text-white text-sm rounded-md px-4 py-3 placeholder:text-steel/30 outline-none focus:border-cyan/30 transition-colors tracking-wide"
              placeholder="jane@business.com"
            />
          </div>
          <div>
            <label for="audit-url" class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium block mb-2">Website URL (if you have one)</label>
            <input
              type="url"
              id="audit-url"
              name="website"
              class="w-full bg-bg/50 border border-white/[0.06] text-white text-sm rounded-md px-4 py-3 placeholder:text-steel/30 outline-none focus:border-cyan/30 transition-colors tracking-wide"
              placeholder="https://yourbusiness.com"
            />
          </div>
          <button
            type="submit"
            class="magnetic-btn w-full border border-white/10 hover:border-cyan/30 text-white font-semibold py-4 text-sm tracking-[0.15em] uppercase transition-all duration-500 hover:shadow-[0_0_30px_rgba(0,229,255,0.12)] bg-gradient-to-r from-white/[0.06] to-white/[0.02] cursor-pointer"
          >
            Request Free Audit
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('audit-form') as HTMLFormElement;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'Sending...';
    btn.disabled = true;

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.get('name'),
          email: data.get('email'),
          message: `Free audit request for: ${data.get('website') || 'No website provided'}`,
          type: 'audit',
        }),
      });
      if (res.ok) {
        btn.textContent = 'Sent — We\'ll Be in Touch';
        form.reset();
      } else {
        btn.textContent = 'Something went wrong — try again';
        btn.disabled = false;
      }
    } catch {
      btn.textContent = 'Error — please call us instead';
      btn.disabled = false;
    }
  });
</script>
