---
---
<section class="relative py-32 bg-bg overflow-hidden">

  <!-- Decorative lines -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-0 right-0 section-line"></div>
    <div class="absolute bottom-0 left-0 right-0 section-line"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">

      <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">
        Personal Service
      </span>

      <h2 class="reveal-up font-display font-bold text-white mb-8" style="font-size:clamp(28px,4vw,56px);">
        You Are <span class="text-metallic-bright">Not a Number</span>
      </h2>

      <div class="reveal-up space-y-5 text-muted text-base leading-relaxed max-w-2xl mx-auto mb-12">
        <p>
          When you call Integrity Web Creations, you get A. Smalls &mdash; the same person who designs your site, writes your code, and answers your questions. Not a call center. Not a junior associate. Not an AI chatbot.
        </p>
        <p class="text-muted/60">
          Every client gets direct access to the person doing the work. That&rsquo;s the difference between a web service and a web <em class="text-silver not-italic">partnership</em>.
        </p>
      </div>

      <!-- Contact strip -->
      <div class="reveal-up inline-flex items-center gap-6 glass-card rounded-full px-8 py-4">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full border border-white/[0.08] flex items-center justify-center">
            <i class="fa-solid fa-phone text-cyan/60 text-[10px]"></i>
          </div>
          <a href="tel:+18432630072" class="text-silver text-sm no-underline hover:text-white transition-colors tracking-wide">
            (843) 263-0072
          </a>
        </div>
        <div class="w-px h-5 bg-white/[0.06]"></div>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full border border-white/[0.08] flex items-center justify-center">
            <i class="fa-solid fa-comment text-cyan/60 text-[10px]"></i>
          </div>
          <a href="sms:+18432630072" class="text-silver text-sm no-underline hover:text-white transition-colors tracking-wide">
            Text A. Smalls
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
