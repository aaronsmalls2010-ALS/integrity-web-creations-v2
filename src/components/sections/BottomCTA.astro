---
---
<section class="relative py-32 bg-bg overflow-hidden">

  <!-- Ambient effects -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-0 right-0 section-line"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] rounded-full bg-cyan/[0.02] blur-[120px]"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
    <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">
      Let&rsquo;s Build
    </span>

    <h2 class="reveal-up font-display font-bold text-white mb-6" style="font-size:clamp(28px,4vw,56px);">
      Ready for a Website<br />
      <span class="text-metallic-bright">That Works For You?</span>
    </h2>

    <p class="reveal-up text-muted text-base leading-relaxed mb-12 max-w-2xl mx-auto">
      Custom-built. Fully managed. Built around your budget. Let&rsquo;s have a real conversation about what your business deserves online.
    </p>

    <div class="reveal-up flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/contact"
        class="magnetic-btn group inline-flex items-center gap-3 border border-white/10 hover:border-cyan/30 text-white font-semibold px-10 py-5 transition-all duration-500 no-underline text-sm tracking-[0.15em] uppercase hover:shadow-[0_0_40px_rgba(0,229,255,0.12)] bg-gradient-to-r from-white/[0.06] to-white/[0.02]"
      >
        Let&rsquo;s Talk
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a
        href="tel:+18432630072"
        class="magnetic-btn inline-flex items-center gap-2 text-steel hover:text-white text-sm tracking-[0.1em] uppercase px-6 py-4 transition-all duration-300 no-underline"
      >
        <i class="fa-solid fa-phone text-cyan/50 text-xs"></i>
        (843) 263-0072
      </a>
    </div>

    <!-- Tagline -->
    <p class="reveal-up mt-16 text-steel/30 text-[10px] tracking-[0.5em] uppercase font-medium">
      Design. Function. Integrity.
    </p>
  </div>
</section>
