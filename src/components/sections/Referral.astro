---
---
<section class="relative py-32 bg-bg overflow-hidden">

  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-0 right-0 section-line"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: content -->
      <div>
        <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">
          Referral Program
        </span>
        <h2 class="reveal-up font-display font-bold text-white mb-6" style="font-size:clamp(28px,3.5vw,48px);">
          Know Someone Who <span class="text-metallic">Needs a Website?</span>
        </h2>
        <p class="reveal-up text-muted text-base leading-relaxed mb-8 max-w-lg">
          We believe in growing through relationships, not ads. Refer a business to Integrity Web Creations and earn a reward when they sign on.
        </p>
      </div>

      <!-- Right: reward cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" data-stagger>
        <div class="glass-card rounded-lg p-6 text-center group hover:border-cyan/15 transition-all duration-500">
          <div class="text-metallic-bright font-display text-3xl font-bold mb-2">$100</div>
          <div class="w-8 h-px bg-gradient-to-r from-transparent via-cyan/30 to-transparent mx-auto mb-3"></div>
          <p class="text-[10px] text-steel tracking-[0.2em] uppercase font-medium mb-1">Current Clients</p>
          <p class="text-muted/50 text-xs leading-relaxed">Credit toward your monthly plan for each successful referral</p>
        </div>
        <div class="glass-card rounded-lg p-6 text-center group hover:border-cyan/15 transition-all duration-500">
          <div class="text-metallic-bright font-display text-3xl font-bold mb-2">$50</div>
          <div class="w-8 h-px bg-gradient-to-r from-transparent via-cyan/30 to-transparent mx-auto mb-3"></div>
          <p class="text-[10px] text-steel tracking-[0.2em] uppercase font-medium mb-1">General Public</p>
          <p class="text-muted/50 text-xs leading-relaxed">Cash reward for referring a business that signs with IWC</p>
        </div>
      </div>

    </div>
  </div>
</section>
