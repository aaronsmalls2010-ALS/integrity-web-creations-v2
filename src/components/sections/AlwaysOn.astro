---
const features = [
  { icon: 'fa-desktop',    title: 'Desktop',    desc: 'Pixel-perfect on every monitor, every resolution.' },
  { icon: 'fa-mobile',     title: 'Mobile',     desc: 'Flawless on every phone your customers carry.' },
  { icon: 'fa-magnifying-glass', title: 'Search', desc: 'Visible in Google where it actually matters.' },
  { icon: 'fa-globe',      title: 'Everywhere', desc: 'Present on every platform, every device, every time.' },
];
---
<section class="relative py-32 bg-bg overflow-hidden">

  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-cyan/[0.015] blur-[100px] pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: content -->
      <div>
        <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">
          Always On
        </span>
        <h2 class="reveal-up font-display font-bold text-white mb-6" style="font-size:clamp(28px,3.5vw,48px);">
          Your Business <span class="text-metallic">Never Sleeps</span>
        </h2>
        <p class="reveal-up text-muted text-base leading-relaxed mb-6 max-w-lg">
          Your website is your hardest-working employee — present on every screen, in every search result, available to every customer 24 hours a day. We build it to perform flawlessly, everywhere.
        </p>
        <p class="reveal-up text-muted/60 text-sm leading-relaxed max-w-lg">
          And you don&rsquo;t manage a thing. We handle every update, every security patch, every optimization. You focus on your business; we keep you visible.
        </p>
      </div>

      <!-- Right: feature cards -->
      <div class="grid grid-cols-2 gap-4" data-stagger>
        {features.map((f) => (
          <div class="group glass-card rounded-lg p-6 hover:border-cyan/15 transition-all duration-500 text-center">
            <div class="w-10 h-10 rounded-full border border-white/[0.06] flex items-center justify-center mx-auto mb-4 group-hover:border-cyan/20 transition-colors duration-500">
              <i class={`fa-solid ${f.icon} text-steel text-sm group-hover:text-cyan transition-colors duration-500`}></i>
            </div>
            <h3 class="text-white text-sm font-semibold mb-1.5 tracking-wide">{f.title}</h3>
            <p class="text-muted/60 text-xs leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
