---
const testimonials = [
  {
    name:     'Dr. Willie Epps',
    business: 'Epps Medical',
    location: 'Savannah, GA',
    initials: 'WE',
    stars:    5,
    quote:    "A. Smalls delivered exactly what I needed — a professional, modern site that represents my practice the right way. The personal attention and care he put into understanding my vision was unlike anything I've experienced working with other developers.",
  },
  {
    name:     'James Baron',
    business: 'Arena Football Players Union',
    location: 'Atlanta, GA',
    initials: 'JB',
    stars:    5,
    quote:    "Integrity Web Creations built a site that truly represents our organization with the professionalism it deserves. A. Smalls was responsive, detailed, and genuinely invested in getting it right. We couldn't be happier.",
  },
  {
    name:     'Pastor Isiah Smalls',
    business: 'The Friendship Baptist Church',
    location: 'Beaufort, SC',
    initials: 'IS',
    stars:    5,
    quote:    "The website A. Smalls created for our church has been a blessing. Visitors find us easily online now, and the site captures the spirit of our congregation. He understood what we needed and delivered beyond our expectations.",
  },
  {
    name:     'Rick & Mandy',
    business: 'The Beaufort Marina',
    location: 'Beaufort, SC',
    initials: 'RM',
    stars:    5,
    quote:    "Finally a web developer who actually listens. A. Smalls took the time to understand our marina, our customers, and what we needed to say online. The result is a site we're proud to send people to.",
  },
];
---
<section class="relative py-32 bg-bg overflow-hidden">

  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-20">
      <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">
        Testimonials
      </span>
      <h2 class="reveal-up font-display font-bold text-white mb-5" style="font-size:clamp(28px,3.5vw,48px);">
        What Our Clients <span class="text-metallic">Say</span>
      </h2>
      <p class="reveal-up text-muted text-base max-w-xl mx-auto">
        Real words from real business owners who trusted us with their online presence.
      </p>
    </div>

    <!-- Testimonial grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-stagger>
      {testimonials.map(t => (
        <div class="group glass-card rounded-lg p-8 hover:border-cyan/15 transition-all duration-500 relative overflow-hidden">
          <!-- Quote mark -->
          <div class="absolute top-6 right-8 text-white/[0.03] font-display text-8xl leading-none select-none">&ldquo;</div>

          <div class="relative">
            <!-- Stars -->
            <div class="flex gap-1 mb-5" aria-label={`${t.stars} out of 5 stars`}>
              {Array.from({ length: t.stars }).map(() => (
                <i class="fa-solid fa-star text-[#c9a94c] text-[10px]" aria-hidden="true"></i>
              ))}
            </div>

            <blockquote class="text-muted/80 text-sm leading-relaxed mb-8 italic">
              &ldquo;{t.quote}&rdquo;
            </blockquote>

            <div class="flex items-center gap-3.5">
              <div class="w-10 h-10 rounded-full border border-white/[0.08] flex items-center justify-center flex-shrink-0">
                <span class="text-metallic text-xs font-bold">{t.initials}</span>
              </div>
              <div>
                <p class="font-semibold text-white text-sm tracking-wide">{t.name}</p>
                <p class="text-steel text-[11px] tracking-wide">{t.business} &middot; {t.location}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
