---
const testimonials = [
  {
    name:     'Dr. Willie Epps',
    business: 'Epps Medical',
    location: 'Savannah, GA',
    initials: 'WE',
    stars:    5,
    quote:    "A. Smalls delivered exactly what I needed — a professional, modern site that represents my practice the right way. The personal attention and care he put into understanding my vision was unlike anything I've experienced working with other developers.",
  },
  {
    name:     'James Baron',
    business: 'Arena Football Players Union',
    location: 'Atlanta, GA',
    initials: 'JB',
    stars:    5,
    quote:    "Integrity Web Creations built a site that truly represents our organization with the professionalism it deserves. A. Smalls was responsive, detailed, and genuinely invested in getting it right. We couldn't be happier.",
  },
  {
    name:     'Pastor Isiah Smalls',
    business: 'The Friendship Baptist Church',
    location: 'Beaufort, SC',
    initials: 'IS',
    stars:    5,
    quote:    "The website A. Smalls created for our church has been a blessing. Visitors find us easily online now, and the site captures the spirit of our congregation. He understood what we needed and delivered beyond our expectations.",
  },
  {
    name:     'Rick & Mandy',
    business: 'The Beaufort Marina',
    location: 'Beaufort, SC',
    initials: 'RM',
    stars:    5,
    quote:    "Finally a web developer who actually listens. A. Smalls took the time to understand our marina, our customers, and what we needed to say online. The result is a site we're proud to send people to.",
  },
];
---

<div class="section-line"></div>

<section id="testimonials" class="bg-bg py-28">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Section header -->
    <div class="text-center mb-16 reveal-up">
      <p class="text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 mb-4">
        Testimonials
      </p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-5">
        What Our <span class="text-metallic">Clients</span> Say
      </h2>
      <p class="text-muted text-base max-w-xl mx-auto leading-relaxed">
        Real words from real business owners who trusted us with their online presence.
      </p>
    </div>

    <!-- Testimonial cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-stagger>
      {testimonials.map((t) => (
        <div class="glass-card group rounded-2xl p-8 hover:border-cyan/20 transition-all duration-300 relative overflow-hidden reveal-up">
          {/* Subtle hover glow */}
          <div class="absolute -bottom-16 -right-16 w-40 h-40 bg-cyan/[0.03] rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" aria-hidden="true"></div>

          <div class="relative z-10">
            {/* Stars */}
            <div class="flex gap-1 mb-5" aria-label={`${t.stars} out of 5 stars`}>
              {Array.from({ length: t.stars }).map(() => (
                <i class="fa-solid fa-star text-[#f59e0b] text-sm" aria-hidden="true"></i>
              ))}
            </div>

            {/* Quote */}
            <blockquote class="text-muted text-sm leading-relaxed mb-8 italic">
              &ldquo;{t.quote}&rdquo;
            </blockquote>

            {/* Client info */}
            <div class="flex items-center gap-3.5">
              <div class="w-11 h-11 rounded-full bg-white/[0.04] border border-white/[0.08] flex items-center justify-center flex-shrink-0">
                <span class="text-cyan/70 font-bold text-sm">{t.initials}</span>
              </div>
              <div>
                <p class="font-display text-sm font-bold text-white">{t.name}</p>
                <p class="text-steel text-xs mt-0.5">{t.business} &middot; {t.location}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
