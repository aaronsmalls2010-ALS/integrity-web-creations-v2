---
const values = [
  { icon: 'fa-handshake',      name: 'Integrity',        desc: 'We do what we say, say what we mean, and always put your business first.' },
  { icon: 'fa-user-tie',       name: 'Personal Service', desc: 'One person, fully invested. Not a ticket number — a real relationship.' },
  { icon: 'fa-dollar-sign',    name: 'Accessibility',    desc: 'Professional web presence should be within reach of every small business.' },
  { icon: 'fa-arrows-rotate',  name: 'Partnership',      desc: 'We grow with you. Your success is our success — month after month.' },
];
---

<div class="section-line"></div>

<section id="about" class="bg-bg py-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Photo placeholder (left) -->
      <div class="relative reveal-left">
        <div class="aspect-[4/5] bg-gradient-to-br from-surface to-card rounded-2xl overflow-hidden flex items-center justify-center max-w-sm mx-auto lg:mx-0 border border-white/[0.06]">
          <div class="text-center px-8">
            <div class="w-24 h-24 rounded-full bg-white/[0.04] border border-white/[0.08] flex items-center justify-center mx-auto mb-5">
              <i class="fa-solid fa-user text-steel text-3xl"></i>
            </div>
            <p class="font-display text-lg font-bold text-white">A. Smalls</p>
            <p class="text-steel text-sm mt-1">Founder & Developer</p>
          </div>
        </div>

        {/* Est badge */}
        <div class="absolute bottom-5 right-0 lg:right-4 glass-card rounded-lg px-5 py-2.5 shadow-lg">
          <span class="text-[10px] font-medium tracking-[0.3em] uppercase text-cyan/60">Est.</span>
          <span class="font-display text-lg font-bold text-white ml-1.5">2010</span>
        </div>
      </div>

      <!-- Story (right) -->
      <div class="reveal-right">
        <p class="text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 mb-4">
          About
        </p>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-8">
          One Person. <span class="text-metallic">Your Full Attention.</span>
        </h2>

        <div class="space-y-5 text-muted text-base leading-relaxed mb-12">
          <p>
            I&rsquo;m A. Smalls &mdash; founder of Integrity Web Creations,
            USC Computer Engineering graduate (Class of 2010), and a Beaufort, SC
            native. After graduating, I came home with one goal: make the same
            quality of web presence that big companies pay agencies tens of
            thousands for accessible to the small businesses that make our
            community what it is.
          </p>
          <p>
            When you work with IWC, you&rsquo;re not dealing with an account
            manager, a sales team, or a rotating roster of developers. You get
            me &mdash; directly &mdash; for every conversation, every design
            decision, and every line of code.
          </p>
          <p>
            I stay small on purpose. That&rsquo;s the point. Bigger
            doesn&rsquo;t mean better &mdash; it means busier. I&rsquo;d rather
            serve fewer clients exceptionally well than many clients adequately.
          </p>
        </div>

        <!-- Core values 2x2 grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5" data-stagger>
          {values.map((v) => (
            <div class="flex items-start gap-3.5 group">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-white/[0.04] border border-white/[0.06] flex items-center justify-center mt-0.5 group-hover:border-cyan/20 transition-colors">
                <i class={`fa-solid ${v.icon} text-cyan/60 text-sm group-hover:text-cyan transition-colors`}></i>
              </div>
              <div>
                <h4 class="font-display text-sm font-bold text-white">{v.name}</h4>
                <p class="text-steel text-xs leading-relaxed mt-1">{v.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
