---
const values = [
  { icon: 'fa-handshake', name: 'Integrity',        desc: 'We do what we say, say what we mean, and always put your business first.' },
  { icon: 'fa-user-tie',  name: 'Personal Service', desc: 'One person, fully invested. Not a ticket number — a real relationship.' },
  { icon: 'fa-dollar-sign', name: 'Accessibility',  desc: 'Professional web presence should be within reach of every small business.' },
  { icon: 'fa-arrows-rotate', name: 'Partnership',  desc: 'We grow with you. Your success is our success — month after month.' },
];
---
<section class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Photo placeholder (left) -->
      <div class="relative">
        <div class="aspect-[4/5] bg-gradient-to-br from-[#f0f4ff] to-[#dbeafe] rounded-2xl overflow-hidden flex items-center justify-center max-w-sm mx-auto lg:mx-0">
          <div class="text-center px-8">
            <div class="w-20 h-20 rounded-full bg-[#dbeafe] flex items-center justify-center mx-auto mb-4">
              <i class="fa-solid fa-user text-[#2563eb] text-2xl"></i>
            </div>
            <p class="text-[#94a3b8] text-sm font-medium">A. Smalls</p>
            <p class="text-[#cbd5e1] text-xs mt-1">Photo coming soon</p>
          </div>
        </div>
        <div class="absolute bottom-4 right-0 lg:right-4 bg-[#2563eb] text-white text-xs font-bold px-4 py-2 rounded-lg shadow-lg">
          Est. 2010
        </div>
      </div>

      <!-- Story (right) -->
      <div>
        <h2 class="font-extrabold text-[#0f172a] mb-6" style="font-size:clamp(22px,3vw,40px);">
          One Person. Your Full Attention.
        </h2>

        <div class="space-y-4 text-[#64748b] text-base leading-relaxed mb-10">
          <p>
            I&rsquo;m A. Smalls &mdash; founder of Integrity Web Creations, USC Computer Engineering graduate (Class of 2010), and a Beaufort, SC native. After graduating, I came home with one goal: make the same quality of web presence that big companies pay agencies tens of thousands for accessible to the small businesses that make our community what it is.
          </p>
          <p>
            When you work with IWC, you&rsquo;re not dealing with an account manager, a sales team, or a rotating roster of developers. You get me &mdash; directly &mdash; for every conversation, every design decision, and every line of code.
          </p>
          <p>
            I stay small on purpose. That&rsquo;s the point. Bigger doesn&rsquo;t mean better &mdash; it means busier. I&rsquo;d rather serve fewer clients exceptionally well than many clients adequately.
          </p>
        </div>

        <!-- Core values 2×2 grid -->
        <div class="grid grid-cols-2 gap-5">
          {values.map(v => (
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-[#eff6ff] flex items-center justify-center mt-0.5">
                <i class={`fa-solid ${v.icon} text-[#2563eb] text-sm`}></i>
              </div>
              <div>
                <h4 class="font-bold text-[#0f172a] text-sm">{v.name}</h4>
                <p class="text-[#64748b] text-xs leading-relaxed mt-0.5">{v.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
