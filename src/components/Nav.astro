---
const links = [
  { href: '/',               label: 'Home' },
  { href: '/about',          label: 'About' },
  { href: '/why-we-matter',  label: 'Why We Matter' },
  { href: '/clients',        label: 'Clients' },
  { href: '/contact',        label: 'Contact' },
];

const pathname = Astro.url.pathname;
---

<header
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <div class="nav-bg absolute inset-0 bg-transparent transition-all duration-500"></div>
  <nav class="relative max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-20">

    <!-- Logo -->
    <a href="/" class="flex flex-col items-start no-underline group" aria-label="Integrity Web Creations home">
      <span class="text-metallic-bright font-display text-xl font-bold tracking-[0.15em] leading-none">
        IWC
      </span>
      <span class="text-[10px] text-steel tracking-[0.35em] uppercase mt-0.5 font-light">
        Integrity Web Creations
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-10 list-none m-0 p-0">
      {links.map(l => (
        <li>
          <a
            href={l.href}
            class={`text-[13px] font-medium tracking-[0.1em] uppercase transition-all duration-300 no-underline relative
              ${pathname === l.href
                ? 'text-white'
                : 'text-steel hover:text-white'
              }`}
          >
            {l.label}
            {pathname === l.href && (
              <span class="absolute -bottom-1.5 left-0 w-full h-px bg-gradient-to-r from-transparent via-cyan to-transparent"></span>
            )}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <a
      href="/contact"
      class="hidden lg:inline-flex magnetic-btn items-center gap-2 border border-white/10 hover:border-cyan/40 text-white text-xs font-semibold tracking-[0.15em] uppercase px-7 py-3 transition-all duration-300 no-underline hover:shadow-[0_0_20px_rgba(0,229,255,0.15)]"
    >
      Start a Project
    </a>

    <!-- Hamburger button -->
    <button
      id="nav-toggle"
      class="lg:hidden flex flex-col justify-center gap-[5px] p-2 cursor-pointer bg-transparent border-none w-10 h-10 relative z-50"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-6 h-[1.5px] bg-white/80 transition-all duration-500 origin-center" id="bar1"></span>
      <span class="block w-4 h-[1.5px] bg-white/80 transition-all duration-500 ml-auto" id="bar2"></span>
      <span class="block w-6 h-[1.5px] bg-white/80 transition-all duration-500 origin-center" id="bar3"></span>
    </button>
  </nav>
</header>

<!-- Mobile overlay -->
<div
  id="mobile-menu"
  role="dialog"
  aria-label="Navigation menu"
  aria-modal="true"
  class="fixed inset-0 z-40 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-500"
  style="background: linear-gradient(180deg, #000d1a 0%, #001529 100%);"
>
  <!-- Decorative lines -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
    <div class="absolute top-1/2 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
    <div class="absolute top-3/4 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
  </div>

  <ul class="relative flex flex-col items-center gap-8 list-none m-0 p-0">
    {links.map((l, i) => (
      <li>
        <a
          href={l.href}
          class="nav-mobile-link text-white text-3xl font-display font-bold no-underline hover:text-cyan transition-all duration-300 tracking-wider"
          style={`transition-delay: ${i * 60}ms;`}
        >
          {l.label}
        </a>
      </li>
    ))}
    <li class="mt-6">
      <a
        href="/contact"
        class="nav-mobile-link inline-flex items-center border border-white/20 text-white text-sm font-semibold tracking-[0.2em] uppercase px-10 py-4 no-underline hover:border-cyan/40 hover:shadow-[0_0_20px_rgba(0,229,255,0.15)] transition-all duration-300"
      >
        Start a Project
      </a>
    </li>
  </ul>

  <!-- Bottom tagline -->
  <p class="absolute bottom-10 text-steel/40 text-[10px] tracking-[0.4em] uppercase">
    Design. Function. Integrity.
  </p>
</div>

<style is:global>
  .nav-scrolled .nav-bg {
    background: rgba(0,13,26,0.85);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement;
  const menu   = document.getElementById('mobile-menu') as HTMLElement;
  const bar1   = document.getElementById('bar1') as HTMLElement;
  const bar2   = document.getElementById('bar2') as HTMLElement;
  const bar3   = document.getElementById('bar3') as HTMLElement;
  let isOpen   = false;

  function openMenu() {
    isOpen = true;
    menu.classList.remove('opacity-0', 'pointer-events-none');
    menu.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
    toggle.setAttribute('aria-expanded', 'true');
    bar1.style.transform = 'translateY(6.5px) rotate(45deg)';
    bar2.style.opacity   = '0';
    bar2.style.transform = 'translateX(10px)';
    bar3.style.transform = 'translateY(-6.5px) rotate(-45deg)';
  }

  function closeMenu() {
    isOpen = false;
    menu.classList.add('opacity-0', 'pointer-events-none');
    menu.classList.remove('opacity-100');
    document.body.style.overflow = '';
    toggle.setAttribute('aria-expanded', 'false');
    bar1.style.transform = '';
    bar2.style.opacity   = '';
    bar2.style.transform = '';
    bar3.style.transform = '';
  }

  toggle.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()));

  document.querySelectorAll('.nav-mobile-link').forEach(link =>
    link.addEventListener('click', closeMenu)
  );

  window.addEventListener('scroll', () => { if (isOpen) closeMenu(); }, { passive: true });
</script>
