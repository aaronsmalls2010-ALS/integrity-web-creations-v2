---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import About from '../components/sections/About.astro';
import TrustStats from '../components/sections/TrustStats.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import BottomCTA from '../components/sections/BottomCTA.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="About — Integrity Web Creations" description="Meet A. Smalls — founder, developer, and your dedicated web partner since 2010.">
  <Nav />
  <main>
    <section class="relative pt-40 pb-20 bg-bg overflow-hidden">
      <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] rounded-full bg-cyan/[0.015] blur-[120px] pointer-events-none"></div>
      <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
        <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">About</span>
        <h1 class="reveal-up font-display font-bold text-white mb-6" style="font-size:clamp(36px,5vw,64px);">Built With <span class="text-metallic-bright">Integrity</span></h1>
        <p class="reveal-up text-muted text-lg leading-relaxed max-w-2xl mx-auto">One person. Full attention. No shortcuts. That's the promise behind every project.</p>
      </div>
    </section>
    <About />
    <TrustStats />
    <Testimonials />
    <BottomCTA />
  </main>
  <Footer />
</BaseLayout>
