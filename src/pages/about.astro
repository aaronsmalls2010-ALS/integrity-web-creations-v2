---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import About from '../components/sections/About.astro';
import TrustStats from '../components/sections/TrustStats.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import BottomCTA from '../components/sections/BottomCTA.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="About — Integrity Web Creations" description="Meet A. Smalls — founder, developer, and the only person you'll ever deal with at Integrity Web Creations. Beaufort, SC since 2010.">
  <Nav />
  <main>
    <!-- Page hero -->
    <section class="relative pt-40 pb-20 bg-bg overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] rounded-full bg-cyan/[0.015] blur-[120px]"></div>
      </div>
      <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
        <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">About</span>
        <h1 class="reveal-up font-display font-bold text-white mb-6" style="font-size:clamp(36px,5vw,64px);">
          Built With <span class="text-metallic-bright">Integrity</span>
        </h1>
        <p class="reveal-up text-muted text-lg leading-relaxed max-w-2xl mx-auto">
          One person. Full attention. No shortcuts. That&rsquo;s the promise behind every project at Integrity Web Creations.
        </p>
      </div>
    </section>

    <About />
    <TrustStats />

    <!-- Extended story section -->
    <section class="relative py-32 bg-bg overflow-hidden">
      <div class="absolute top-0 left-0 right-0 section-line" aria-hidden="true"></div>
      <div class="max-w-3xl mx-auto px-6 lg:px-8">
        <h2 class="reveal-up font-display font-bold text-white mb-8 text-center" style="font-size:clamp(24px,3vw,40px);">
          The <span class="text-metallic">IWC Story</span>
        </h2>
        <div class="space-y-5 text-muted text-base leading-relaxed">
          <p class="reveal-up">
            In 2010, fresh from the University of South Carolina with a degree in Computer Engineering, A. Smalls came back to Beaufort with a simple observation: the small businesses that make the Lowcountry special were invisible online. The barbershop, the church, the marina, the medical practice &mdash; they deserved the same digital presence as any Fortune 500 company.
          </p>
          <p class="reveal-up text-muted/60">
            Integrity Web Creations was founded on the belief that premium web quality shouldn&rsquo;t require premium enterprise budgets. Fifteen years later, that mission hasn&rsquo;t changed. Every site is still hand-coded, every client still gets direct access, and every project is still treated like it&rsquo;s the only one that matters.
          </p>
          <p class="reveal-up text-muted/60">
            From Beaufort to Savannah to Atlanta, IWC has grown through referrals &mdash; not advertising. Because when you take care of people, they tell other people. That&rsquo;s how it should work.
          </p>
        </div>
      </div>
    </section>

    <Testimonials />
    <BottomCTA />
  </main>
  <Footer />
</BaseLayout>
