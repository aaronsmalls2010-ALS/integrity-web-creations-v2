---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Page Not Found — Integrity Web Creations">
  <Nav />
  <main class="min-h-screen flex items-center justify-center bg-bg">
    <div class="text-center px-6">
      <span class="text-metallic font-display font-bold block mb-4" style="font-size:clamp(80px,12vw,160px);line-height:1;">404</span>
      <h1 class="text-white font-display font-bold text-2xl mb-4 tracking-wide">Page Not Found</h1>
      <p class="text-muted text-sm mb-8 max-w-md mx-auto leading-relaxed">
        The page you&rsquo;re looking for doesn&rsquo;t exist or has been moved.
      </p>
      <a
        href="/"
        class="magnetic-btn inline-flex items-center border border-white/10 hover:border-cyan/30 text-white text-xs font-semibold tracking-[0.15em] uppercase px-8 py-3.5 transition-all duration-300 no-underline hover:shadow-[0_0_20px_rgba(0,229,255,0.15)]"
      >
        Back to Home
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
