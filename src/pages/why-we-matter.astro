---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import BottomCTA from '../components/sections/BottomCTA.astro';
import Footer from '../components/Footer.astro';

const reasons = [
  {
    number: '01',
    title: 'Your Website Is Your First Impression',
    body: 'Before a customer ever walks through your door, calls your number, or reads your menu — they Google you. What they find (or don\'t find) determines whether they take the next step. A professional, modern website isn\'t optional anymore. It\'s expected.',
  },
  {
    number: '02',
    title: 'Templates Don\'t Tell Your Story',
    body: 'Squarespace, Wix, GoDaddy — they all promise easy. But easy means generic. Your business isn\'t generic, and your website shouldn\'t be either. A custom-built site says something a template never can: this business takes itself seriously.',
  },
  {
    number: '03',
    title: 'You Deserve a Partner, Not a Vendor',
    body: 'Big agencies assign you a ticket number. Freelancers disappear. At IWC, you get a real person who answers the phone, knows your business, and treats your site like their own. Because they are the same person who built it.',
  },
  {
    number: '04',
    title: 'Neglected Sites Cost You Money',
    body: 'An outdated website doesn\'t just look bad — it actively drives customers away. Slow load times, broken links, security warnings, and missing information all tell customers the same thing: this business doesn\'t care about the details.',
  },
  {
    number: '05',
    title: 'Local Matters',
    body: 'When something goes wrong — or when you have an idea at 9pm on a Tuesday — you want someone who\'s a phone call away. Not a chatbot. Not a ticket queue in another timezone. A person in your community who shows up.',
  },
];
---
<BaseLayout title="Why We Matter — Integrity Web Creations" description="Why your business needs a dedicated web partner, not a template builder. The case for Integrity Web Creations.">
  <Nav />
  <main>
    <!-- Page hero -->
    <section class="relative pt-40 pb-20 bg-bg overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 right-1/4 w-[600px] h-[600px] rounded-full bg-cyan/[0.015] blur-[120px]"></div>
      </div>
      <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
        <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">The Case</span>
        <h1 class="reveal-up font-display font-bold text-white mb-6" style="font-size:clamp(36px,5vw,64px);">
          Why <span class="text-metallic-bright">We Matter</span>
        </h1>
        <p class="reveal-up text-muted text-lg leading-relaxed max-w-2xl mx-auto">
          In a world of templates, chatbots, and agencies that don&rsquo;t know your name &mdash; here&rsquo;s why a dedicated web partner changes everything.
        </p>
      </div>
    </section>

    <!-- Reasons -->
    <section class="relative py-20 bg-bg overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 lg:px-8 space-y-20">
        {reasons.map(r => (
          <div class="reveal-up relative">
            <div class="flex items-start gap-6">
              <span class="text-metallic font-display text-5xl font-bold leading-none flex-shrink-0 select-none opacity-20">
                {r.number}
              </span>
              <div>
                <h2 class="font-display font-bold text-white text-xl mb-4 tracking-wide">{r.title}</h2>
                <p class="text-muted/70 text-base leading-relaxed">{r.body}</p>
              </div>
            </div>
            <div class="section-line mt-16"></div>
          </div>
        ))}
      </div>
    </section>

    <BottomCTA />
  </main>
  <Footer />
</BaseLayout>
