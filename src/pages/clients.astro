---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import FeaturedWork from '../components/sections/FeaturedWork.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import BottomCTA from '../components/sections/BottomCTA.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Clients — Integrity Web Creations" description="Real sites built for real businesses across the Southeast.">
  <Nav />
  <main>
    <section class="relative pt-40 pb-20 bg-bg overflow-hidden">
      <div class="absolute top-1/3 left-1/3 w-[600px] h-[600px] rounded-full bg-cyan/[0.015] blur-[120px] pointer-events-none"></div>
      <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
        <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">Portfolio</span>
        <h1 class="reveal-up font-display font-bold text-white mb-6" style="font-size:clamp(36px,5vw,64px);">Our <span class="text-metallic-bright">Clients</span></h1>
        <p class="reveal-up text-muted text-lg leading-relaxed max-w-2xl mx-auto">Every project gets the same level of dedication and craftsmanship.</p>
      </div>
    </section>
    <FeaturedWork />
    <Testimonials />
    <BottomCTA />
  </main>
  <Footer />
</BaseLayout>
