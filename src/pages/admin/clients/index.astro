---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listClients } from '../../../lib/db/clients';
const clients = await listClients(Astro.cookies);
---
<AdminLayout title="Clients">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Clients</h1>
    <a href="/admin/clients/new" class="btn-primary">New client</a>
  </div>
  <div class="overflow-x-auto">
    <table class="mt-6 w-full text-sm">
      <thead>
        <tr class="text-left text-[#9fb3c8]">
          <th scope="col" class="p-2">Name</th>
          <th scope="col">Business</th>
          <th scope="col">Email</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody>
        {clients.map((c) => (
          <tr class="border-t border-white/[0.08] hover:bg-white/5">
            <td class="p-2"><a class="font-medium text-[#00e5ff] hover:underline" href={`/admin/clients/${c.id}`}>{c.name}</a></td>
            <td>{c.business_name}</td>
            <td>{c.email}</td>
            <td>{c.status}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {clients.length === 0 && <p class="mt-4 text-sm text-[#9fb3c8]">No clients yet — create your first one.</p>}
</AdminLayout>
