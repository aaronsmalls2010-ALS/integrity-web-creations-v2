---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listDrafts, getSettings } from '../../../lib/outreach/db';

const [drafts, settings] = await Promise.all([listDrafts(), getSettings()]);
const noEmail = drafts.filter((d: any) => !d.lead?.email);
---
<AdminLayout title="Review Queue">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-bold text-[#e6edf5]">Review queue <span class="text-base font-normal text-[#9fb3c8]">({drafts.length} draft{drafts.length === 1 ? '' : 's'})</span></h1>
    <div class="flex items-center gap-2">
      <button id="batchBtn" class="btn-primary" disabled>Approve selected → batch</button>
    </div>
  </div>
  <p class="mt-2 text-sm text-[#9fb3c8]">
    Every email sends exactly as written here, plus the automatic signature, physical address, and unsubscribe
    link (required by CAN-SPAM — injected at send time, can't be forgotten).
    {noEmail.length > 0 && <span class="text-amber-300"> {noEmail.length} draft(s) below have no email on the lead — add one on the lead page before they can batch.</span>}
  </p>

  <div class="mt-4 space-y-4">
    {drafts.length === 0 && <div class="card p-6 text-sm text-[#9fb3c8]">No drafts waiting. Generate openers from a lead page, or approve research candidates.</div>}
    {drafts.map((d: any) => (
      <div class="card p-4" data-id={d.id}>
        <div class="flex flex-wrap items-center gap-3">
          <input type="checkbox" class="sel h-4 w-4 accent-[#00e5ff]" data-id={d.id} disabled={!d.lead?.email} />
          <a class="font-semibold text-[#00e5ff] hover:underline" href={`/admin/outreach/leads/${d.lead?.id}`}>{d.lead?.business_name}</a>
          <span class="text-xs text-[#9fb3c8]">{d.lead?.category} · {d.lead?.town ?? '—'} · step {d.sequence_step}</span>
          <span class="text-xs text-[#9fb3c8]">{d.lead?.email ?? 'NO EMAIL'}</span>
          <span class="ml-auto flex gap-2">
            <button class="saveBtn btn-ghost text-xs" data-id={d.id}>Save edits</button>
            <button class="cancelBtn rounded-lg px-2 py-1 text-xs text-[#ff6b6b] hover:bg-[#ff6b6b]/10" data-id={d.id}>Discard</button>
          </span>
        </div>
        <div class="mt-3 grid gap-2">
          <input class="subj input w-full font-medium" data-id={d.id} value={d.subject} maxlength="200" aria-label="Subject" />
          <textarea class="body input w-full font-sans" data-id={d.id} rows="9" aria-label="Body">{d.body}</textarea>
        </div>
        <p class="err mt-2 hidden text-sm text-[#ff6b6b]" role="alert"></p>
      </div>
    ))}
  </div>

  <script>
    const sels = () => [...document.querySelectorAll<HTMLInputElement>('.sel:checked')].map((c) => c.dataset.id!);
    const batchBtn = document.getElementById('batchBtn') as HTMLButtonElement;
    document.querySelectorAll('.sel').forEach((c) => c.addEventListener('change', () => {
      const n = sels().length;
      batchBtn.disabled = n === 0;
      batchBtn.textContent = n ? `Approve ${n} → batch` : 'Approve selected → batch';
    }));

    const cardErr = (id: string, msg: string) => {
      const card = document.querySelector(`.card[data-id="${id}"] .err`) as HTMLElement;
      if (card) { card.textContent = msg; card.classList.remove('hidden'); }
    };

    document.querySelectorAll('.saveBtn').forEach((b) => b.addEventListener('click', async () => {
      const id = (b as HTMLElement).dataset.id!;
      const subject = (document.querySelector(`.subj[data-id="${id}"]`) as HTMLInputElement).value;
      const body = (document.querySelector(`.body[data-id="${id}"]`) as HTMLTextAreaElement).value;
      const res = await fetch(`/api/admin/outreach/messages/${id}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ subject, body }),
      });
      if (!res.ok) { const o = await res.json().catch(() => ({})); cardErr(id, o.error ?? 'Save failed'); return; }
      (b as HTMLElement).textContent = 'Saved ✓';
      setTimeout(() => ((b as HTMLElement).textContent = 'Save edits'), 1500);
    }));

    document.querySelectorAll('.cancelBtn').forEach((b) => b.addEventListener('click', async () => {
      const id = (b as HTMLElement).dataset.id!;
      const res = await fetch(`/api/admin/outreach/messages/${id}`, { method: 'DELETE' });
      if (res.ok) document.querySelector(`.card[data-id="${id}"]`)?.remove();
    }));

    batchBtn.addEventListener('click', async () => {
      const ids = sels();
      if (!ids.length) return;
      // Save any unsaved edits on selected cards first, so what you approved is what sends.
      for (const id of ids) {
        const subject = (document.querySelector(`.subj[data-id="${id}"]`) as HTMLInputElement).value;
        const body = (document.querySelector(`.body[data-id="${id}"]`) as HTMLTextAreaElement).value;
        await fetch(`/api/admin/outreach/messages/${id}`, {
          method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ subject, body }),
        });
      }
      const name = `Batch ${new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} (${ids.length})`;
      const res = await fetch('/api/admin/outreach/batches', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, messageIds: ids }),
      });
      const out = await res.json();
      if (!res.ok) { alertBar(out.error ?? 'Batch creation failed'); return; }
      window.location.href = `/admin/outreach/batches/${out.batch.id}`;
    });

    function alertBar(msg: string) {
      const p = document.createElement('p');
      p.className = 'mt-3 rounded-lg bg-[#ff6b6b]/10 p-3 text-sm text-[#ff6b6b]';
      p.setAttribute('role', 'alert');
      p.textContent = msg;
      document.querySelector('h1')?.after(p);
    }
  </script>
</AdminLayout>
