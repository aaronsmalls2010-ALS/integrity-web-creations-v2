---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDashboard } from '../../lib/db/reports';
import { formatUSD } from '../../lib/money';
import { statusBadge } from '../../lib/statusBadge';
const admin = Astro.locals.admin!;
const today = new Date().toLocaleDateString('en-CA', { timeZone: 'America/New_York' });
const m = await getDashboard(Astro.cookies, today);
---
<AdminLayout title="Dashboard">
  <h1 class="text-2xl font-bold text-[#e6edf5]">Dashboard</h1>
  <p class="mt-1 text-sm text-[#9fb3c8]">Signed in as {admin.email}</p>
  <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="card p-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-[#9fb3c8]">Outstanding</p>
      <p class="mt-1 text-2xl font-bold text-[#e6edf5]">{formatUSD(m.outstandingCents)}</p>
    </div>
    <div class="card p-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-[#9fb3c8]">Overdue</p>
      <p class="mt-1 text-2xl font-bold text-[#ff6b6b]">{formatUSD(m.overdueCents)}</p>
      <p class="text-xs text-[#9fb3c8]">{m.overdueCount} invoice(s)</p>
    </div>
    <div class="card p-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-[#9fb3c8]">Paid this month</p>
      <p class="mt-1 text-2xl font-bold text-emerald-300">{formatUSD(m.paidThisMonthCents)}</p>
    </div>
  </div>
  <div class="mt-6 flex flex-wrap gap-2">
    <a href="/admin/invoices/new" class="btn-primary">New invoice</a>
    <a href="/admin/clients/new" class="btn-ghost">New client</a>
    <a href="/admin/reports" class="btn-ghost">Reports</a>
  </div>
  <section class="mt-8">
    <h2 class="font-semibold text-[#e6edf5]">Recent invoices</h2>
    <div class="overflow-x-auto">
      <table class="mt-2 w-full text-sm">
        <thead>
          <tr class="text-left text-[#9fb3c8]">
            <th scope="col" class="p-2">Number</th>
            <th scope="col">Client</th>
            <th scope="col">Status</th>
            <th scope="col">Total</th>
            <th scope="col">Balance</th>
          </tr>
        </thead>
        <tbody>
          {m.recent.map((i: any) => (
            <tr class="border-t border-white/[0.08] hover:bg-white/5">
              <td class="p-2"><a class="text-[#00e5ff] hover:underline" href={`/admin/invoices/${i.id}`}>{i.invoice_number ?? 'DRAFT'}</a></td>
              <td>{i.client?.name}</td>
              <td><span class:list={["rounded-full px-2 py-0.5 text-xs font-semibold uppercase", statusBadge(i.status)]}>{i.status}</span></td>
              <td>{formatUSD(i.total_cents)}</td>
              <td>{formatUSD(i.balance_cents)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</AdminLayout>
