---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDashboard } from '../../lib/db/reports';
import { formatUSD } from '../../lib/money';
const admin = Astro.locals.admin!;
const today = new Date().toLocaleDateString('en-CA', { timeZone: 'America/New_York' });
const m = await getDashboard(Astro.cookies, today);
---
<AdminLayout title="Dashboard">
  <h1 class="text-2xl font-bold text-[#e6edf5]">Dashboard</h1>
  <p class="mt-1 text-sm text-[#8aa0b6]">Signed in as {admin.email}</p>
  <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="rounded-xl border border-white/[0.08] bg-[#0d1b2c] p-5 shadow-lg shadow-black/20">
      <p class="text-xs font-semibold uppercase tracking-wide text-[#8aa0b6]">Outstanding</p>
      <p class="mt-1 text-2xl font-bold text-[#e6edf5]">{formatUSD(m.outstandingCents)}</p>
    </div>
    <div class="rounded-xl border border-white/[0.08] bg-[#0d1b2c] p-5 shadow-lg shadow-black/20">
      <p class="text-xs font-semibold uppercase tracking-wide text-[#8aa0b6]">Overdue</p>
      <p class="mt-1 text-2xl font-bold text-red-400">{formatUSD(m.overdueCents)}</p>
      <p class="text-xs text-[#8aa0b6]">{m.overdueCount} invoice(s)</p>
    </div>
    <div class="rounded-xl border border-white/[0.08] bg-[#0d1b2c] p-5 shadow-lg shadow-black/20">
      <p class="text-xs font-semibold uppercase tracking-wide text-[#8aa0b6]">Paid this month</p>
      <p class="mt-1 text-2xl font-bold text-[#00e5ff]">{formatUSD(m.paidThisMonthCents)}</p>
    </div>
  </div>
  <div class="mt-6 flex flex-wrap gap-2">
    <a href="/admin/invoices/new" class="rounded-lg px-4 py-2 text-sm font-semibold text-[#001018] transition hover:opacity-90" style="background-image:linear-gradient(135deg,#0066ff,#00e5ff)">New invoice</a>
    <a href="/admin/clients/new" class="rounded-lg border border-[#243040] bg-[#0d1b2c] px-4 py-2 text-sm text-[#e6edf5] transition hover:border-[#00e5ff] hover:text-[#00e5ff]">New client</a>
    <a href="/admin/reports" class="rounded-lg border border-[#243040] bg-[#0d1b2c] px-4 py-2 text-sm text-[#e6edf5] transition hover:border-[#00e5ff] hover:text-[#00e5ff]">Reports</a>
  </div>
  <section class="mt-8">
    <h2 class="font-semibold text-[#e6edf5]">Recent invoices</h2>
    <table class="mt-2 w-full text-sm">
      <thead><tr class="text-left text-[#8aa0b6]"><th class="p-2">Number</th><th>Client</th><th>Status</th><th>Total</th><th>Balance</th></tr></thead>
      <tbody>
        {m.recent.map((i: any) => (
          <tr class="border-t border-white/[0.08] hover:bg-white/5">
            <td class="p-2"><a class="text-[#00e5ff] hover:underline" href={`/admin/invoices/${i.id}`}>{i.invoice_number ?? 'DRAFT'}</a></td>
            <td>{i.client?.name}</td><td>{i.status}</td><td>{formatUSD(i.total_cents)}</td><td>{formatUSD(i.balance_cents)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</AdminLayout>
