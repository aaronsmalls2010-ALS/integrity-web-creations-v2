---
export const prerender = false;
---
<html lang="en"><head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Two-Factor — Integrity Web Creations</title>
<meta name="robots" content="noindex" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<style>
  :root{--dark:#000d1a;--dark2:#001529;--cyan:#00e5ff;--bright:#0066ff;--dim:#00bfff;--blue:#0052cc;}
  *{box-sizing:border-box;}
  body{margin:0;min-height:100vh;display:grid;place-items:center;padding:24px;
    background:radial-gradient(1100px 560px at 50% -8%,rgba(0,229,255,.13),transparent 60%),linear-gradient(135deg,#000d1a,#001529);
    color:#fff;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;}
  .wrap{width:100%;max-width:420px;}
  .brand{text-align:center;margin-bottom:28px;}
  .mark{width:56px;height:56px;margin:0 auto 16px;display:grid;place-items:center;border-radius:14px;
    background:#000d1a;border:1px solid rgba(255,255,255,.1);box-shadow:0 0 40px rgba(0,229,255,.18);}
  .mark span{font-size:30px;font-weight:800;background:linear-gradient(135deg,#0066ff,#00e5ff);
    -webkit-background-clip:text;background-clip:text;color:transparent;}
  .logo{font-size:1.25rem;font-weight:700;letter-spacing:.5px;}
  .logo .accent{color:var(--cyan);}
  .tagline{margin-top:6px;font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:2.5px;color:var(--dim);}
  .c-form{background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.08);border-radius:24px;padding:40px;}
  .c-form h1{margin:0 0 8px;text-align:center;font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,.62);}
  .hint{margin:0 0 20px;text-align:center;font-size:.85rem;color:rgba(255,255,255,.5);line-height:1.5;}
  .fg{margin-bottom:18px;}
  label{display:block;font-size:.82em;color:rgba(255,255,255,.62);margin-bottom:8px;font-weight:500;}
  input{width:100%;background:rgba(255,255,255,.052);border:1px solid rgba(255,255,255,.1);color:#fff;
    padding:14px 18px;border-radius:12px;font-size:.93em;font-family:inherit;outline:none;transition:all .3s ease;-webkit-appearance:none;letter-spacing:3px;text-align:center;}
  input::placeholder{color:rgba(255,255,255,.28);letter-spacing:normal;}
  input:focus{border-color:var(--cyan);background:rgba(0,229,255,.04);box-shadow:0 0 25px rgba(0,229,255,.1);}
  .btn-outline{width:100%;background:transparent;color:#fff;padding:13px;border-radius:12px;font-size:.95em;font-weight:500;
    cursor:pointer;border:1.5px solid rgba(255,255,255,.25);transition:all .3s ease;margin-bottom:18px;}
  .btn-outline:hover{border-color:var(--cyan);color:var(--cyan);background:rgba(0,229,255,.05);}
  .qr{display:block;margin:0 auto 18px;background:#fff;padding:10px;border-radius:12px;width:200px;height:200px;}
  .btn-submit{width:100%;background:linear-gradient(135deg,#0052cc,#00bfff);color:#fff;padding:16px;border-radius:12px;
    font-size:1em;font-weight:600;cursor:pointer;border:none;margin-top:6px;transition:all .3s ease;box-shadow:0 0 38px rgba(0,82,204,.4);}
  .btn-submit:hover{transform:translateY(-2px);}
  .btn-submit:disabled,.btn-outline:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none;}
  .err{color:#ff6b6b;font-size:.85em;margin:0 0 14px;}
  .hidden{display:none;}
  .foot{text-align:center;margin-top:22px;font-size:.75rem;color:rgba(255,255,255,.35);}
</style>
</head>
<body>
  <div class="wrap">
    <div class="brand">
      <div class="mark"><span>I</span></div>
      <div class="logo"><span class="accent">integrity</span> WEB CREATIONS</div>
      <div class="tagline">Custom Web Design · Beaufort, SC</div>
    </div>
    <div class="c-form">
      <h1>Set up two-factor</h1>
      <p class="hint">Scan the QR with your authenticator app, then enter the 6-digit code to finish.</p>
      <button id="enroll" class="btn-outline">Show QR to enroll</button>
      <img id="qr" class="qr hidden" alt="TOTP QR" />
      <div class="fg"><label for="code">Authenticator code</label><input id="code" inputmode="numeric" placeholder="123456" /></div>
      <p id="err" class="err hidden"></p>
      <button id="verify" class="btn-submit">Verify</button>
    </div>
    <p class="foot">© Integrity Web Creations</p>
  </div>

  <script>
    let factorId: string | null = null;
    const err = document.getElementById('err')!;
    const enrollBtn = document.getElementById('enroll') as HTMLButtonElement;
    const verifyBtn = document.getElementById('verify') as HTMLButtonElement;
    verifyBtn.disabled = true;
    enrollBtn.addEventListener('click', async () => {
      const res = await fetch('/api/admin/auth/mfa-enroll', { method: 'POST' });
      const j = await res.json();
      if (!res.ok) { err.textContent = j.error; err.classList.remove('hidden'); return; }
      factorId = j.factorId;
      const img = document.getElementById('qr') as HTMLImageElement;
      img.src = j.qr; img.classList.remove('hidden');
      enrollBtn.disabled = true;
      verifyBtn.disabled = false;
    });
    verifyBtn.addEventListener('click', async () => {
      err.classList.add('hidden');
      if (!factorId) { err.textContent = 'Enroll first'; err.classList.remove('hidden'); return; }
      const code = (document.getElementById('code') as HTMLInputElement).value.trim();
      const res = await fetch('/api/admin/auth/mfa-verify', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ factorId, code }),
      });
      if (res.ok) { window.location.href = '/admin'; }
      else { const j = await res.json(); err.textContent = j.error; err.classList.remove('hidden'); }
    });
  </script>
</body></html>
