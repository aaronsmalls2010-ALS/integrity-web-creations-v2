---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSettings } from '../../lib/db/settings';
const s = await getSettings(Astro.cookies);
---
<AdminLayout title="Settings">
  <h1 class="text-2xl font-bold text-[#e6edf5]">Settings</h1>

  <form id="f" class="mt-6 grid max-w-2xl grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="sm:col-span-2">
      <label class="lbl" for="business_name">Business name *</label>
      <input id="business_name" name="business_name" value={s.business_name ?? ''} placeholder="Integrity Web Creations" required class="input" />
    </div>
    <div>
      <label class="lbl" for="address_line1">Address line 1</label>
      <input id="address_line1" name="address_line1" value={s.address_line1 ?? ''} placeholder="123 Main St" class="input" />
    </div>
    <div>
      <label class="lbl" for="address_line2">Address line 2</label>
      <input id="address_line2" name="address_line2" value={s.address_line2 ?? ''} placeholder="Suite 100" class="input" />
    </div>
    <div>
      <label class="lbl" for="city">City</label>
      <input id="city" name="city" value={s.city ?? ''} placeholder="Gulfport" class="input" />
    </div>
    <div>
      <label class="lbl" for="state">State</label>
      <input id="state" name="state" value={s.state ?? ''} placeholder="MS" class="input" />
    </div>
    <div>
      <label class="lbl" for="postal_code">ZIP</label>
      <input id="postal_code" name="postal_code" value={s.postal_code ?? ''} placeholder="39501" class="input" />
    </div>
    <div>
      <label class="lbl" for="from_email">From email</label>
      <input id="from_email" name="from_email" value={s.from_email ?? ''} placeholder="invoices@yourdomain.com" class="input" />
    </div>
    <div>
      <label class="lbl" for="reply_to">Reply-to email</label>
      <input id="reply_to" name="reply_to" value={s.reply_to ?? ''} placeholder="you@yourdomain.com" class="input" />
    </div>
    <div>
      <label class="lbl" for="invoice_number_prefix">Invoice prefix</label>
      <input id="invoice_number_prefix" name="invoice_number_prefix" value={s.invoice_number_prefix ?? ''} placeholder="IWC-" class="input" />
    </div>
    <div>
      <label class="lbl" for="default_due_days">Default due days</label>
      <input id="default_due_days" name="default_due_days" type="number" value={s.default_due_days ?? 14} placeholder="14" class="input" />
    </div>
    <div>
      <label class="lbl" for="default_tax_rate">Default tax rate</label>
      <input id="default_tax_rate" name="default_tax_rate" type="number" step="0.001" value={s.default_tax_rate ?? 0} placeholder="e.g. 0.07" class="input" />
    </div>
    <div>
      <label class="lbl" for="next_invoice_number">Next invoice number <span class="text-[#9fb3c8]">(auto)</span></label>
      <input id="next_invoice_number" value={s.next_invoice_number ?? ''} readonly title="Next invoice number (managed automatically)" class="input opacity-50 cursor-not-allowed" />
    </div>
    <div class="sm:col-span-2">
      <label class="lbl" for="default_terms">Default terms</label>
      <textarea id="default_terms" name="default_terms" placeholder="Payment is due within 14 days…" class="input">{s.default_terms ?? ''}</textarea>
    </div>
    <div class="sm:col-span-2">
      <label class="lbl" for="payment_instructions">Payment instructions</label>
      <textarea id="payment_instructions" name="payment_instructions" placeholder="Shown on invoices — e.g. Venmo, bank transfer details" class="input">{s.payment_instructions ?? ''}</textarea>
    </div>
    <p id="err" class="sm:col-span-2 hidden text-sm text-[#ff6b6b]" role="alert"></p>
    <p id="ok" class="sm:col-span-2 hidden text-sm text-[#34d399]" aria-live="polite"></p>
    <button type="submit" class="sm:col-span-2 btn-primary">Save settings</button>
  </form>

  <section class="mt-10 max-w-2xl">
    <h2 class="font-semibold text-[#e6edf5]">Logo</h2>
    {s.logo_storage_path && <p class="text-sm text-[#9fb3c8]">Current: {s.logo_storage_path}</p>}
    <form id="logo" class="mt-2 flex items-center gap-2">
      <input type="file" name="logo" accept="image/*" required class="text-sm text-[#9fb3c8]" />
      <button type="submit" class="btn-ghost text-sm">Upload</button>
    </form>
    <p id="logoMsg" class="mt-1 hidden text-sm" aria-live="polite"></p>
  </section>

  <script>
    document.getElementById('f')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = form.querySelector('button[type=submit],button:not([type])') as HTMLButtonElement;
      const prevText = btn.textContent!;
      btn.disabled = true; btn.textContent = 'Saving…';
      const body = Object.fromEntries(new FormData(form).entries());
      const err = document.getElementById('err')!; const ok = document.getElementById('ok')!;
      err.classList.add('hidden'); ok.classList.add('hidden');
      const res = await fetch('/api/admin/settings', {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      btn.disabled = false; btn.textContent = prevText;
      if (res.ok) { ok.textContent = 'Saved.'; ok.classList.remove('hidden'); }
      else { err.textContent = (await res.json()).error; err.classList.remove('hidden'); }
    });
    document.getElementById('logo')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as HTMLFormElement);
      const msg = document.getElementById('logoMsg')!;
      const res = await fetch('/api/admin/settings', { method: 'POST', body: fd });
      msg.classList.remove('hidden');
      msg.textContent = res.ok ? 'Logo uploaded.' : ((await res.json()).error ?? 'Upload failed');
      msg.className = 'mt-1 text-sm ' + (res.ok ? 'text-[#34d399]' : 'text-[#ff6b6b]');
    });
  </script>
</AdminLayout>
