---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSettings } from '../../lib/db/settings';
const s = await getSettings(Astro.cookies);
---
<AdminLayout title="Settings">
  <h1 class="text-2xl font-bold">Settings</h1>

  <form id="f" class="mt-6 grid max-w-2xl grid-cols-2 gap-3">
    <input name="business_name" value={s.business_name ?? ''} placeholder="Business name *" required class="col-span-2 rounded border p-2" />
    <input name="address_line1" value={s.address_line1 ?? ''} placeholder="Address line 1" class="rounded border p-2" />
    <input name="address_line2" value={s.address_line2 ?? ''} placeholder="Address line 2" class="rounded border p-2" />
    <input name="city" value={s.city ?? ''} placeholder="City" class="rounded border p-2" />
    <input name="state" value={s.state ?? ''} placeholder="State" class="rounded border p-2" />
    <input name="postal_code" value={s.postal_code ?? ''} placeholder="ZIP" class="rounded border p-2" />
    <input name="from_email" value={s.from_email ?? ''} placeholder="From email" class="rounded border p-2" />
    <input name="reply_to" value={s.reply_to ?? ''} placeholder="Reply-to email" class="rounded border p-2" />
    <input name="invoice_number_prefix" value={s.invoice_number_prefix ?? ''} placeholder="Invoice prefix (e.g. IWC-)" class="rounded border p-2" />
    <input name="default_due_days" type="number" value={s.default_due_days ?? 14} placeholder="Default due days" class="rounded border p-2" />
    <input name="default_tax_rate" type="number" step="0.001" value={s.default_tax_rate ?? 0} placeholder="Default tax rate (e.g. 0.07)" class="rounded border p-2" />
    <input value={s.next_invoice_number ?? ''} readonly title="Next invoice number (managed automatically)" class="rounded border bg-slate-100 p-2" />
    <textarea name="default_terms" placeholder="Default terms" class="col-span-2 rounded border p-2">{s.default_terms ?? ''}</textarea>
    <textarea name="payment_instructions" placeholder="Payment instructions (shown on invoices)" class="col-span-2 rounded border p-2">{s.payment_instructions ?? ''}</textarea>
    <p id="err" class="col-span-2 hidden text-sm text-red-600"></p>
    <p id="ok" class="col-span-2 hidden text-sm text-green-700"></p>
    <button class="col-span-2 rounded bg-blue-700 p-2 font-semibold text-white">Save settings</button>
  </form>

  <section class="mt-10 max-w-2xl">
    <h2 class="font-semibold">Logo</h2>
    {s.logo_storage_path && <p class="text-sm text-slate-500">Current: {s.logo_storage_path}</p>}
    <form id="logo" class="mt-2 flex items-center gap-2">
      <input type="file" name="logo" accept="image/*" required class="text-sm" />
      <button class="rounded bg-slate-700 px-3 py-2 text-sm font-semibold text-white">Upload</button>
    </form>
    <p id="logoMsg" class="mt-1 hidden text-sm"></p>
  </section>

  <script>
    document.getElementById('f')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const body = Object.fromEntries(new FormData(e.target as HTMLFormElement).entries());
      const err = document.getElementById('err')!; const ok = document.getElementById('ok')!;
      err.classList.add('hidden'); ok.classList.add('hidden');
      const res = await fetch('/api/admin/settings', {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      if (res.ok) { ok.textContent = 'Saved.'; ok.classList.remove('hidden'); }
      else { err.textContent = (await res.json()).error; err.classList.remove('hidden'); }
    });
    document.getElementById('logo')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as HTMLFormElement);
      const msg = document.getElementById('logoMsg')!;
      const res = await fetch('/api/admin/settings', { method: 'POST', body: fd });
      msg.classList.remove('hidden');
      msg.textContent = res.ok ? 'Logo uploaded.' : ((await res.json()).error ?? 'Upload failed');
      msg.className = 'mt-1 text-sm ' + (res.ok ? 'text-green-700' : 'text-red-600');
    });
  </script>
</AdminLayout>
