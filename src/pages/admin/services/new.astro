---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listServices } from '../../../lib/db/services';
const existing = await listServices(Astro.cookies, true);
const categories = [...new Set((existing ?? []).map((s: any) => s.category).filter(Boolean))];
const subcategories = [...new Set((existing ?? []).map((s: any) => s.subcategory).filter(Boolean))];
const UNITS = ['one-time', 'month', 'year', 'hour', 'page', 'each'];
---
<AdminLayout title="New Service">
  <h1 class="text-2xl font-bold text-[#e6edf5]">New service</h1>
  <form id="f" class="mt-6 grid max-w-xl grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="sm:col-span-2">
      <label class="lbl" for="name">Name *</label>
      <input id="name" name="name" placeholder="e.g. Monthly Hosting" required class="input" />
    </div>
    <div class="sm:col-span-2">
      <label class="lbl" for="description">Description</label>
      <textarea id="description" name="description" placeholder="Brief description of this service" class="input"></textarea>
    </div>
    <div>
      <label class="lbl" for="category">Category</label>
      <input id="category" name="category" list="catList" placeholder="e.g. Hosting & Infrastructure" class="input" />
      <datalist id="catList">{categories.map((c) => <option value={c} />)}</datalist>
    </div>
    <div>
      <label class="lbl" for="subcategory">Subcategory</label>
      <input id="subcategory" name="subcategory" list="subcatList" placeholder="e.g. Domains" class="input" />
      <datalist id="subcatList">{subcategories.map((c) => <option value={c} />)}</datalist>
    </div>
    <div>
      <label class="lbl" for="unit">Billing unit</label>
      <select id="unit" name="unit" class="input">
        {UNITS.map((u) => <option value={u}>{u}</option>)}
      </select>
    </div>
    <div>
      <label class="lbl" for="price">Default price (USD)</label>
      <input id="price" name="price" placeholder="e.g. 35.00" class="input" />
    </div>
    <div>
      <label class="lbl" for="default_quantity">Default quantity</label>
      <input id="default_quantity" name="default_quantity" type="number" step="0.01" value="1" class="input" />
    </div>
    <div class="sm:col-span-2">
      <label class="flex items-center gap-2 text-sm text-[#9fb3c8] cursor-pointer">
        <input type="checkbox" name="taxable" class="rounded" /> Taxable
      </label>
    </div>
    <p id="err" class="sm:col-span-2 hidden text-sm text-[#ff6b6b]" role="alert"></p>
    <button type="submit" class="sm:col-span-2 btn-primary">Save</button>
  </form>
  <script>
    document.getElementById('f')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = form.querySelector('button[type=submit],button:not([type])') as HTMLButtonElement;
      const prevText = btn.textContent!;
      btn.disabled = true; btn.textContent = 'Saving…';
      const body = {
        name: (form.elements.namedItem('name') as HTMLInputElement).value,
        description: (form.elements.namedItem('description') as HTMLTextAreaElement).value,
        category: (form.elements.namedItem('category') as HTMLInputElement).value,
        subcategory: (form.elements.namedItem('subcategory') as HTMLInputElement).value,
        unit: (form.elements.namedItem('unit') as HTMLSelectElement).value,
        price: (form.elements.namedItem('price') as HTMLInputElement).value,
        default_quantity: (form.elements.namedItem('default_quantity') as HTMLInputElement).value,
        taxable: (form.elements.namedItem('taxable') as HTMLInputElement).checked,
      };
      const res = await fetch('/api/admin/services', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      const j = await res.json();
      const err = document.getElementById('err')!;
      if (res.ok) window.location.href = `/admin/services/${j.service.id}`;
      else { err.textContent = j.error; err.classList.remove('hidden'); btn.disabled = false; btn.textContent = prevText; }
    });
  </script>
</AdminLayout>
