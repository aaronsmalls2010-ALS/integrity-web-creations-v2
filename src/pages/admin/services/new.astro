---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="New Service">
  <h1 class="text-2xl font-bold">New service</h1>
  <form id="f" class="mt-6 grid max-w-xl grid-cols-2 gap-3">
    <input name="name" placeholder="Name * (e.g. Monthly Hosting)" required class="col-span-2 rounded border p-2" />
    <textarea name="description" placeholder="Description" class="col-span-2 rounded border p-2"></textarea>
    <input name="price" placeholder="Default price USD (e.g. 35.00)" class="rounded border p-2" />
    <input name="default_quantity" type="number" step="0.01" value="1" class="rounded border p-2" />
    <label class="col-span-2 flex items-center gap-2 text-sm"><input type="checkbox" name="taxable" /> Taxable</label>
    <p id="err" class="col-span-2 hidden text-sm text-red-600"></p>
    <button class="col-span-2 rounded bg-blue-700 p-2 font-semibold text-white">Save</button>
  </form>
  <script>
    document.getElementById('f')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const body = {
        name: (form.elements.namedItem('name') as HTMLInputElement).value,
        description: (form.elements.namedItem('description') as HTMLTextAreaElement).value,
        price: (form.elements.namedItem('price') as HTMLInputElement).value,
        default_quantity: (form.elements.namedItem('default_quantity') as HTMLInputElement).value,
        taxable: (form.elements.namedItem('taxable') as HTMLInputElement).checked,
      };
      const res = await fetch('/api/admin/services', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      const j = await res.json();
      const err = document.getElementById('err')!;
      if (res.ok) window.location.href = `/admin/services/${j.service.id}`;
      else { err.textContent = j.error; err.classList.remove('hidden'); }
    });
  </script>
</AdminLayout>
