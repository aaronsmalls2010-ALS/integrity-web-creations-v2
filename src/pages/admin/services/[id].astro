---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getService } from '../../../lib/db/services';
import { centsToDollars } from '../../../lib/money';
const s = await getService(Astro.cookies, Astro.params.id!);
---
<AdminLayout title={s.name}>
  <h1 class="text-2xl font-bold text-[#e6edf5]">{s.name}</h1>
  <form id="f" class="mt-6 grid max-w-xl grid-cols-1 sm:grid-cols-2 gap-4" data-id={s.id}>
    <div class="sm:col-span-2">
      <label class="lbl" for="name">Name *</label>
      <input id="name" name="name" value={s.name} required class="input" />
    </div>
    <div class="sm:col-span-2">
      <label class="lbl" for="description">Description</label>
      <textarea id="description" name="description" class="input">{s.description ?? ''}</textarea>
    </div>
    <div>
      <label class="lbl" for="price">Default price (USD)</label>
      <input id="price" name="price" value={centsToDollars(s.default_unit_price_cents)} class="input" />
    </div>
    <div>
      <label class="lbl" for="default_quantity">Default quantity</label>
      <input id="default_quantity" name="default_quantity" type="number" step="0.01" value={s.default_quantity} class="input" />
    </div>
    <div class="sm:col-span-2 flex flex-col gap-2">
      <label class="flex items-center gap-2 text-sm text-[#9fb3c8] cursor-pointer">
        <input type="checkbox" name="taxable" checked={s.taxable} class="rounded" /> Taxable
      </label>
      <label class="flex items-center gap-2 text-sm text-[#9fb3c8] cursor-pointer">
        <input type="checkbox" name="active" checked={s.active} class="rounded" /> Active
      </label>
    </div>
    <p id="err" class="sm:col-span-2 hidden text-sm text-[#ff6b6b]" role="alert"></p>
    <div class="sm:col-span-2 flex gap-2">
      <button type="submit" class="btn-primary">Save</button>
      <button type="button" id="deactivate" class="btn-ghost" style="color:#ff6b6b">Deactivate</button>
    </div>
  </form>
  <script>
    const form = document.getElementById('f') as HTMLFormElement;
    const id = form.dataset.id;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit],button:not([type])') as HTMLButtonElement;
      const prevText = btn.textContent!;
      btn.disabled = true; btn.textContent = 'Saving…';
      const body = {
        name: (form.elements.namedItem('name') as HTMLInputElement).value,
        description: (form.elements.namedItem('description') as HTMLTextAreaElement).value,
        price: (form.elements.namedItem('price') as HTMLInputElement).value,
        default_quantity: (form.elements.namedItem('default_quantity') as HTMLInputElement).value,
        taxable: (form.elements.namedItem('taxable') as HTMLInputElement).checked,
        active: (form.elements.namedItem('active') as HTMLInputElement).checked,
      };
      const res = await fetch(`/api/admin/services/${id}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      const err = document.getElementById('err')!;
      if (res.ok) location.reload();
      else { err.textContent = (await res.json()).error; err.classList.remove('hidden'); btn.disabled = false; btn.textContent = prevText; }
    });
    document.getElementById('deactivate')!.addEventListener('click', async () => {
      if (!confirm('Deactivate this service?')) return;
      await fetch(`/api/admin/services/${id}`, { method: 'DELETE' });
      window.location.href = '/admin/services';
    });
  </script>
</AdminLayout>
