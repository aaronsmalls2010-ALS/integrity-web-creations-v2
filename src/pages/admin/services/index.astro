---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listServices } from '../../../lib/db/services';
import { formatUSD } from '../../../lib/money';
const services = await listServices(Astro.cookies, true);
---
<AdminLayout title="Services">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Services</h1>
    <a href="/admin/services/new" class="btn-primary">New service</a>
  </div>
  <div class="overflow-x-auto">
    <table class="mt-6 w-full text-sm">
      <thead>
        <tr class="text-left text-[#9fb3c8]">
          <th scope="col" class="p-2">Name</th>
          <th scope="col">Category</th>
          <th scope="col">Price</th>
          <th scope="col">Unit</th>
          <th scope="col">Taxable</th>
          <th scope="col">Active</th>
        </tr>
      </thead>
      <tbody>
        {services.map((s) => (
          <tr class="border-t border-white/[0.08] hover:bg-white/5">
            <td class="p-2"><a class="font-medium text-[#00e5ff] hover:underline" href={`/admin/services/${s.id}`}>{s.name}</a></td>
            <td class="text-[#9fb3c8]">{s.category ?? '—'}{s.subcategory ? ` › ${s.subcategory}` : ''}</td>
            <td>{formatUSD(s.default_unit_price_cents)}</td>
            <td class="text-[#9fb3c8]">{s.unit ?? '—'}</td>
            <td>{s.taxable ? 'Yes' : 'No'}</td>
            <td>{s.active ? 'Yes' : 'No'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {services.length === 0 && <p class="mt-4 text-sm text-[#9fb3c8]">No services yet — create your first one.</p>}
</AdminLayout>
