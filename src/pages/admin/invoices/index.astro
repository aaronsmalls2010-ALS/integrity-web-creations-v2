---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listInvoices } from '../../../lib/db/invoices';
import { formatUSD } from '../../../lib/money';
import { statusBadge } from '../../../lib/statusBadge';
const invoices = await listInvoices(Astro.cookies);
---
<AdminLayout title="Invoices">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Invoices</h1>
    <a href="/admin/invoices/new" class="btn-primary">New invoice</a>
  </div>
  <div class="overflow-x-auto">
    <table class="mt-6 w-full text-sm">
      <thead>
        <tr class="text-left text-[#9fb3c8]">
          <th scope="col" class="p-2">Number</th>
          <th scope="col">Client</th>
          <th scope="col">Status</th>
          <th scope="col">Total</th>
          <th scope="col">Balance</th>
          <th scope="col">Due</th>
        </tr>
      </thead>
      <tbody>
        {invoices.map((inv: any) => (
          <tr class="border-t border-white/[0.08] hover:bg-white/5">
            <td class="p-2"><a class="font-medium text-[#00e5ff] hover:underline" href={`/admin/invoices/${inv.id}`}>{inv.invoice_number ?? 'DRAFT'}</a></td>
            <td>{inv.client?.name}</td>
            <td><span class:list={["rounded-full px-2 py-0.5 text-xs font-semibold uppercase", statusBadge(inv.status)]}>{inv.status}</span></td>
            <td>{formatUSD(inv.total_cents)}</td>
            <td>{formatUSD(inv.balance_cents)}</td>
            <td>{inv.due_date}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {invoices.length === 0 && <p class="mt-4 text-sm text-[#9fb3c8]">No invoices yet — create your first one.</p>}
</AdminLayout>
