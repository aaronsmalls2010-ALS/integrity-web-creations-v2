---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getInvoice } from '../../../lib/db/invoices';
import { getAdminClient } from '../../../lib/supabase/admin';
import { refundableCents } from '../../../lib/db/refunds';
import { formatUSD } from '../../../lib/money';
import { statusBadge } from '../../../lib/statusBadge';
const inv: any = await getInvoice(Astro.cookies, Astro.params.id!);
const base = Astro.url.origin;
// Refunds are service-role-only; read them with the admin client (page is admin-gated).
const sbAdmin = getAdminClient();
const { data: refunds } = await sbAdmin.from('refunds').select('*').eq('invoice_id', inv.id).order('created_at', { ascending: false });
const refundable = inv.stripe_payment_intent_id ? await refundableCents(sbAdmin, inv.id) : 0;
const canRefund = refundable > 0 && inv.status !== 'draft' && inv.status !== 'void';
---
<AdminLayout title={inv.invoice_number ?? 'Draft invoice'}>

  <!-- ── Header ── -->
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-bold text-[#e6edf5]">
      {inv.invoice_number ?? 'DRAFT'} &middot; {inv.client.name}
    </h1>
    <span class={`rounded-full px-3 py-1 text-xs font-semibold uppercase ${statusBadge(inv.status)}`}>
      {inv.status}
    </span>
  </div>

  <!-- ── Line items ── -->
  <div class="card mt-6 overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-white/8 text-left">
          <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Description</th>
          <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Qty</th>
          <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Unit price</th>
          <th scope="col" class="px-4 py-3 text-right font-medium text-[#9fb3c8]">Amount</th>
        </tr>
      </thead>
      <tbody>
        {inv.lines.sort((a:any,b:any)=>a.sort_order-b.sort_order).map((l:any) => (
          <tr class="border-t border-white/8">
            <td class="px-4 py-3 text-[#e6edf5]">{l.description}</td>
            <td class="px-4 py-3 text-[#9fb3c8]">{l.quantity}</td>
            <td class="px-4 py-3 text-[#9fb3c8]">{formatUSD(l.unit_price_cents)}</td>
            <td class="px-4 py-3 text-right text-[#e6edf5]">{formatUSD(l.amount_cents)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- ── Totals ── -->
  <div class="mt-4 space-y-1 text-right text-sm text-[#9fb3c8]">
    <div>Subtotal: <span class="text-[#e6edf5]">{formatUSD(inv.subtotal_cents)}</span></div>
    <div>Discount: <span class="text-[#e6edf5]">&minus;{formatUSD(inv.discount_cents)}</span></div>
    <div>Tax: <span class="text-[#e6edf5]">{formatUSD(inv.tax_cents)}</span></div>
    <div class="text-lg font-bold text-[#e6edf5]">Total: {formatUSD(inv.total_cents)}</div>
    <div>Balance: <span class="text-[#e6edf5]">{formatUSD(inv.balance_cents)}</span></div>
  </div>

  <!-- ── Public link ── -->
  {inv.public_token && (
    <p class="mt-4 text-sm text-[#9fb3c8]">
      Public link:&nbsp;<a class="text-[#00bfff] hover:underline" href={`/i/${inv.public_token}`}>{base}/i/{inv.public_token}</a>
    </p>
  )}

  <!-- ── Action error banner ── -->
  <p id="actionErr" role="alert" class="hidden mt-4 rounded-lg bg-[#ff6b6b]/15 px-4 py-2 text-sm text-[#ff6b6b]"></p>
  <p id="actionOk" role="status" class="hidden mt-4 rounded-lg bg-[#22c55e]/15 px-4 py-2 text-sm text-[#22c55e]"></p>

  <!-- ── Action buttons ── -->
  <div class="mt-6 flex flex-wrap gap-2" data-id={inv.id}>
    {inv.status === 'draft' && (
      <a href={`/api/admin/invoices/${inv.id}/pdf?preview=1`} target="_blank" rel="noopener" class="btn-ghost">Preview PDF</a>
    )}
    {inv.status === 'draft' && (
      <button id="issue" class="btn-primary">Issue</button>
    )}
    {inv.status === 'draft' && (
      <button id="issueEmail" class="btn-primary">Issue &amp; email</button>
    )}
    {inv.status !== 'draft' && inv.status !== 'paid' && inv.status !== 'void' && (
      <button id="pay" class="btn-primary">Record payment</button>
    )}
    {inv.status !== 'draft' && inv.status !== 'paid' && inv.status !== 'void' && (
      <button id="markPaid" class="btn-ghost" style="color:#22c55e;border-color:#22c55e55;">Mark as paid</button>
    )}
    {canRefund && (
      <button id="refund" class="btn-ghost" style="color:#f59e0b;border-color:#f59e0b55;" data-refundable={refundable}>Refund</button>
    )}
    {inv.status !== 'draft' && (
      <a href={`/api/admin/invoices/${inv.id}/pdf`} class="btn-ghost">Download PDF</a>
    )}
    {inv.status !== 'draft' && inv.status !== 'void' && (
      <button id="resend" class="btn-ghost">Email to client</button>
    )}
    <button id="dup" class="btn-ghost">Duplicate</button>
    {inv.status !== 'paid' && inv.status !== 'void' && (
      <button id="void" class="btn-ghost" style="color:#ff6b6b;border-color:#ff6b6b33;">
        {inv.status === 'draft' ? 'Delete' : 'Void'}
      </button>
    )}
  </div>

  <!-- ── Payments ── -->
  <section class="mt-8">
    <h2 class="font-semibold text-[#e6edf5]">Payments</h2>
    {inv.payments.length > 0 ? (
      <div class="card mt-3 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/8 text-left">
              <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Amount</th>
              <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Method</th>
              <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Date</th>
              <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Reference</th>
            </tr>
          </thead>
          <tbody>
            {inv.payments.map((p:any) => (
              <tr class="border-t border-white/8">
                <td class="px-4 py-3 text-[#e6edf5]">{formatUSD(p.amount_cents)}</td>
                <td class="px-4 py-3 text-[#9fb3c8]">{p.method}</td>
                <td class="px-4 py-3 text-[#9fb3c8]">{new Date(p.paid_at).toLocaleDateString()}</td>
                <td class="px-4 py-3 text-[#9fb3c8]">{p.reference ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <p class="mt-2 text-sm text-[#9fb3c8]">No payments recorded yet.</p>
    )}
  </section>

  <!-- ── Refunds ── -->
  {refunds && refunds.length > 0 && (
    <section class="mt-8">
      <h2 class="font-semibold text-[#e6edf5]">Refunds</h2>
      <div class="card mt-3 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/8 text-left">
              <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Amount</th>
              <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Date</th>
              <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Reason</th>
              <th scope="col" class="px-4 py-3 font-medium text-[#9fb3c8]">Stripe ID</th>
            </tr>
          </thead>
          <tbody>
            {refunds.map((r: any) => (
              <tr class="border-t border-white/8">
                <td class="px-4 py-3 text-[#f59e0b]">−{formatUSD(r.amount_cents)}</td>
                <td class="px-4 py-3 text-[#9fb3c8]">{new Date(r.created_at).toLocaleDateString()}</td>
                <td class="px-4 py-3 text-[#9fb3c8]">{r.reason ?? '—'}</td>
                <td class="px-4 py-3 text-[#9fb3c8] font-mono text-xs">{r.stripe_refund_id ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <!-- ── Refund modal ── -->
  <div id="refundModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4"
       role="dialog" aria-modal="true" aria-labelledby="refundTitle">
    <form id="refundForm" class="card w-full max-w-sm space-y-4 p-6">
      <h2 id="refundTitle" class="text-lg font-bold text-[#e6edf5]">Refund payment</h2>
      <p class="text-sm text-[#9fb3c8]">Refundable: <strong class="text-[#e6edf5]">{formatUSD(refundable)}</strong> (via Stripe). Leave the amount full for a complete refund.</p>
      <div>
        <label class="lbl" for="refundAmount">Amount (USD)</label>
        <input id="refundAmount" class="input" inputmode="decimal" />
      </div>
      <div>
        <label class="lbl" for="refundReason">Reason (optional)</label>
        <input id="refundReason" class="input" placeholder="e.g. Service cancelled" />
      </div>
      <p id="refundErr" role="alert" class="hidden text-sm text-[#ff6b6b]"></p>
      <div class="flex justify-end gap-2">
        <button type="button" id="refundCancel" class="btn-ghost">Cancel</button>
        <button type="submit" id="refundSubmit" class="btn-primary">Issue refund</button>
      </div>
    </form>
  </div>

  <!-- ── Confirm modal ── -->
  <div id="confirmModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4"
       role="dialog" aria-modal="true" aria-labelledby="confirmTitle">
    <div class="card w-full max-w-sm p-6">
      <h2 id="confirmTitle" class="text-lg font-bold text-[#e6edf5]"></h2>
      <p id="confirmMsg" class="mt-2 text-sm text-[#9fb3c8]"></p>
      <div class="mt-5 flex justify-end gap-2">
        <button id="confirmCancel" class="btn-ghost">Cancel</button>
        <button id="confirmOk" class="btn-primary">Confirm</button>
      </div>
    </div>
  </div>

  <!-- ── Payment modal ── -->
  <div id="payModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4"
       role="dialog" aria-modal="true" aria-labelledby="payTitle">
    <form id="payForm" class="card w-full max-w-sm space-y-4 p-6">
      <h2 id="payTitle" class="text-lg font-bold text-[#e6edf5]">Record payment</h2>
      <div>
        <label class="lbl" for="payAmount">Amount (USD)</label>
        <input id="payAmount" class="input" inputmode="decimal" placeholder="0.00" required />
      </div>
      <div>
        <label class="lbl" for="payDate">Payment date</label>
        <input id="payDate" type="date" class="input" />
      </div>
      <div>
        <label class="lbl" for="payMethod">Method</label>
        <select id="payMethod" class="input">
          <option value="check">Check</option>
          <option value="zelle">Zelle</option>
          <option value="cash">Cash</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="lbl" for="payRef">Reference (optional)</label>
        <input id="payRef" class="input" />
      </div>
      <p id="payErr" role="alert" class="hidden text-sm text-[#ff6b6b]"></p>
      <div class="flex justify-end gap-2">
        <button type="button" id="payCancel" class="btn-ghost">Cancel</button>
        <button type="submit" id="paySubmit" class="btn-primary">Record</button>
      </div>
    </form>
  </div>

  <script>
    import { dollarsToCents } from '../../../lib/money';

    /* ── helpers ── */
    const wrap = document.querySelector('[data-id]') as HTMLElement;
    const id = wrap.dataset.id!;

    function showActionErr(msg: string) {
      const el = document.getElementById('actionErr')!;
      el.textContent = msg;
      el.classList.remove('hidden');
      document.getElementById('actionOk')!.classList.add('hidden');
    }

    function showActionOk(msg: string) {
      const el = document.getElementById('actionOk')!;
      el.textContent = msg;
      el.classList.remove('hidden');
      document.getElementById('actionErr')!.classList.add('hidden');
    }

    /* ── confirm dialog ── */
    function confirmDialog(title: string, msg: string, okLabel = 'Confirm'): Promise<boolean> {
      return new Promise((resolve) => {
        const m = document.getElementById('confirmModal')!;
        document.getElementById('confirmTitle')!.textContent = title;
        document.getElementById('confirmMsg')!.textContent = msg;
        const okBtn = document.getElementById('confirmOk') as HTMLButtonElement;
        okBtn.textContent = okLabel;
        m.classList.remove('hidden');
        m.classList.add('flex');
        document.body.style.overflow = 'hidden';
        const cleanup = (val: boolean) => {
          m.classList.add('hidden');
          m.classList.remove('flex');
          document.body.style.overflow = '';
          okBtn.onclick = null;
          resolve(val);
        };
        okBtn.onclick = () => cleanup(true);
        document.getElementById('confirmCancel')!.onclick = () => cleanup(false);
        m.onclick = (e: MouseEvent) => { if (e.target === m) cleanup(false); };
      });
    }

    /* ── pay modal helpers ── */
    function openPayModal() {
      const m = document.getElementById('payModal')!;
      (document.getElementById('payAmount') as HTMLInputElement).value = '';
      (document.getElementById('payRef') as HTMLInputElement).value = '';
      // default the payment date to today
      (document.getElementById('payDate') as HTMLInputElement).value = new Date().toISOString().slice(0, 10);
      const errEl = document.getElementById('payErr')!;
      errEl.textContent = '';
      errEl.classList.add('hidden');
      m.classList.remove('hidden');
      m.classList.add('flex');
      document.body.style.overflow = 'hidden';
      (document.getElementById('payAmount') as HTMLInputElement).focus();
    }

    function closePayModal() {
      const m = document.getElementById('payModal')!;
      m.classList.add('hidden');
      m.classList.remove('flex');
      document.body.style.overflow = '';
    }

    /* ── issue (assign number + lock, no email) ── */
    async function issue(email: boolean) {
      const ok = email
        ? await confirmDialog('Issue & email invoice?', 'Assigns the permanent invoice number, locks the invoice, and emails it to the client now.', 'Issue & email')
        : await confirmDialog('Issue invoice?', 'Assigns the permanent invoice number and locks the invoice. The client is NOT emailed — you can send it afterward with “Email to client”.', 'Issue');
      if (!ok) return;
      const btnIds = ['issue', 'issueEmail'];
      btnIds.forEach((b) => { const el = document.getElementById(b) as HTMLButtonElement | null; if (el) el.disabled = true; });
      try {
        const r = await fetch(`/api/admin/invoices/${id}/send`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const j = await r.json().catch(() => ({}));
        if (!r.ok) { showActionErr(j.error ?? 'Failed to issue invoice.'); return; }
        // Issued OK. If an email was requested but didn't go out, surface why on reload.
        if (j.emailError) { sessionStorage.setItem('invoiceFlash', j.emailError); }
        else if (email && j.emailed) { sessionStorage.setItem('invoiceFlashOk', 'Invoice issued and emailed to the client.'); }
        else { sessionStorage.setItem('invoiceFlashOk', 'Invoice issued. Use “Email to client” when you’re ready to send it.'); }
        location.reload();
      } finally {
        btnIds.forEach((b) => { const el = document.getElementById(b) as HTMLButtonElement | null; if (el) el.disabled = false; });
      }
    }
    document.getElementById('issue')?.addEventListener('click', () => issue(false));
    document.getElementById('issueEmail')?.addEventListener('click', () => issue(true));

    /* ── flash message after issue reload ── */
    {
      const flashErr = sessionStorage.getItem('invoiceFlash');
      const flashOk = sessionStorage.getItem('invoiceFlashOk');
      if (flashErr) { showActionErr(flashErr); sessionStorage.removeItem('invoiceFlash'); }
      else if (flashOk) { showActionOk(flashOk); sessionStorage.removeItem('invoiceFlashOk'); }
    }

    /* ── email to client (works for first send or re-send; same number/token) ── */
    document.getElementById('resend')?.addEventListener('click', async () => {
      if (!(await confirmDialog('Email invoice to client?', 'Emails the current invoice to the client (no changes to the invoice number or contents).', 'Email'))) return;
      const btn = document.getElementById('resend') as HTMLButtonElement;
      btn.disabled = true;
      try {
        const r = await fetch(`/api/admin/invoices/${id}/resend`, { method: 'POST' });
        const j = await r.json().catch(() => ({}));
        if (r.ok) showActionOk(`Email sent to ${j.to}.`);
        else showActionErr(j.error ?? 'Failed to email invoice.');
      } finally { btn.disabled = false; }
    });

    /* ── mark as paid (records a payment for the full balance) ── */
    document.getElementById('markPaid')?.addEventListener('click', async () => {
      if (!(await confirmDialog('Mark invoice as paid?', 'Records a payment for the full remaining balance and marks the invoice paid. Use this for invoices settled by check, cash, or Zelle.', 'Mark paid'))) return;
      const btn = document.getElementById('markPaid') as HTMLButtonElement;
      btn.disabled = true;
      try {
        const r = await fetch(`/api/admin/invoices/${id}/mark-paid`, { method: 'POST' });
        if (r.ok) location.reload();
        else { showActionErr((await r.json().catch(() => ({}))).error ?? 'Failed to mark invoice as paid.'); btn.disabled = false; }
      } catch { showActionErr('Failed to mark invoice as paid.'); btn.disabled = false; }
    });

    /* ── refund (Stripe) ── */
    const refundBtn = document.getElementById('refund');
    if (refundBtn) {
      const refundableCentsVal = Number((refundBtn as HTMLElement).dataset.refundable || '0');
      const openRefund = () => {
        const m = document.getElementById('refundModal')!;
        (document.getElementById('refundAmount') as HTMLInputElement).value = (refundableCentsVal / 100).toFixed(2);
        (document.getElementById('refundReason') as HTMLInputElement).value = '';
        const err = document.getElementById('refundErr')!; err.textContent = ''; err.classList.add('hidden');
        m.classList.remove('hidden'); m.classList.add('flex'); document.body.style.overflow = 'hidden';
      };
      const closeRefund = () => {
        const m = document.getElementById('refundModal')!;
        m.classList.add('hidden'); m.classList.remove('flex'); document.body.style.overflow = '';
      };
      refundBtn.addEventListener('click', openRefund);
      document.getElementById('refundCancel')?.addEventListener('click', closeRefund);
      document.getElementById('refundModal')?.addEventListener('click', (e: Event) => {
        if ((e as MouseEvent).target === document.getElementById('refundModal')) closeRefund();
      });
      document.getElementById('refundForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const err = document.getElementById('refundErr')!; err.textContent = ''; err.classList.add('hidden');
        let amount_cents: number;
        try { amount_cents = dollarsToCents((document.getElementById('refundAmount') as HTMLInputElement).value.trim() || '0'); }
        catch { err.textContent = 'Enter a valid dollar amount.'; err.classList.remove('hidden'); return; }
        if (amount_cents <= 0) { err.textContent = 'Amount must be greater than $0.00.'; err.classList.remove('hidden'); return; }
        if (amount_cents > refundableCentsVal) { err.textContent = 'Amount exceeds the refundable balance.'; err.classList.remove('hidden'); return; }
        const reason = (document.getElementById('refundReason') as HTMLInputElement).value.trim() || undefined;
        const btn = document.getElementById('refundSubmit') as HTMLButtonElement;
        btn.disabled = true; btn.textContent = 'Refunding…';
        const r = await fetch(`/api/admin/invoices/${id}/refund`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ amount_cents, reason }),
        });
        if (r.ok) { closeRefund(); location.reload(); }
        else {
          const j = await r.json().catch(() => ({}));
          err.textContent = j.error ?? 'Refund failed.'; err.classList.remove('hidden');
          btn.disabled = false; btn.textContent = 'Issue refund';
        }
      });
    }

    /* ── duplicate ── */
    document.getElementById('dup')?.addEventListener('click', async () => {
      const r = await fetch(`/api/admin/invoices/${id}/duplicate`, { method: 'POST' });
      const j = await r.json();
      if (r.ok) location.href = `/admin/invoices/${j.invoice.id}`;
      else showActionErr(j.error ?? 'Failed to duplicate invoice.');
    });

    /* ── void / delete ── */
    document.getElementById('void')?.addEventListener('click', async () => {
      const btn = document.getElementById('void')!;
      const isDraft = btn.textContent?.trim() === 'Delete';
      const title = isDraft ? 'Delete draft?' : 'Void invoice?';
      const msg = isDraft
        ? 'This draft will be permanently deleted and cannot be recovered.'
        : 'This will void the invoice and mark it as uncollectible.';
      if (!(await confirmDialog(title, msg, isDraft ? 'Delete' : 'Void'))) return;
      const r = await fetch(`/api/admin/invoices/${id}/void`, { method: 'POST' });
      if (r.ok) location.href = '/admin/invoices';
      else showActionErr((await r.json()).error ?? 'Failed to void invoice.');
    });

    /* ── record payment ── */
    document.getElementById('pay')?.addEventListener('click', openPayModal);
    document.getElementById('payCancel')?.addEventListener('click', closePayModal);
    document.getElementById('payModal')?.addEventListener('click', (e: Event) => {
      if ((e as MouseEvent).target === document.getElementById('payModal')) closePayModal();
    });

    document.getElementById('payForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errEl = document.getElementById('payErr')!;
      errEl.textContent = '';
      errEl.classList.add('hidden');

      const rawAmt = (document.getElementById('payAmount') as HTMLInputElement).value.trim();
      let amount_cents: number;
      try {
        amount_cents = dollarsToCents(rawAmt);
      } catch {
        errEl.textContent = 'Enter a valid dollar amount (e.g. 250.00).';
        errEl.classList.remove('hidden');
        return;
      }
      if (amount_cents <= 0) {
        errEl.textContent = 'Amount must be greater than $0.00.';
        errEl.classList.remove('hidden');
        return;
      }

      const method = (document.getElementById('payMethod') as HTMLSelectElement).value;
      const reference = (document.getElementById('payRef') as HTMLInputElement).value.trim() || undefined;
      const paid_at = (document.getElementById('payDate') as HTMLInputElement).value || undefined;
      const submitBtn = document.getElementById('paySubmit') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Recording…';

      const r = await fetch('/api/admin/payments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ invoice_id: id, amount_cents, method, reference, paid_at }),
      });

      if (r.ok) {
        closePayModal();
        location.reload();
      } else {
        const j = await r.json().catch(() => ({}));
        errEl.textContent = j.error ?? 'Failed to record payment.';
        errEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Record';
      }
    });
  </script>
</AdminLayout>
