---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listSchedules } from '../../../lib/db/recurring';
import { formatUSD } from '../../../lib/money';
const schedules = (await listSchedules(Astro.cookies)) as any[];
const total = (items: any[]) => (items ?? []).reduce((s: number, l: any) => s + Math.round(l.quantity * l.unit_price_cents), 0);
---
<AdminLayout title="Recurring">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Recurring schedules</h1>
    <a href="/admin/recurring/new" class="btn-primary">New schedule</a>
  </div>
  <div class="overflow-x-auto">
    <table class="mt-6 w-full text-sm">
      <thead>
        <tr class="text-left text-[#9fb3c8]">
          <th scope="col" class="p-2">Name</th>
          <th scope="col">Client</th>
          <th scope="col">Interval</th>
          <th scope="col">Next run</th>
          <th scope="col">Amount</th>
          <th scope="col">Mode</th>
          <th scope="col">Active</th>
        </tr>
      </thead>
      <tbody>
        {schedules.map((s) => (
          <tr class="border-t border-white/[0.08] hover:bg-white/5">
            <td class="p-2"><a class="text-[#00e5ff] hover:underline" href={`/admin/recurring/${s.id}`}>{s.name}</a></td>
            <td>{s.client?.name}</td>
            <td>{s.interval_count > 1 ? `${s.interval_count}× ` : ''}{s.interval}</td>
            <td>{s.next_run_date}</td>
            <td>{formatUSD(total(s.line_items))}</td>
            <td>{s.auto_send ? 'Auto-send' : 'Draft'}</td>
            <td>{s.active ? 'Yes' : 'No'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {schedules.length === 0 && <p class="mt-3 text-sm text-[#9fb3c8]">No recurring schedules yet.</p>}
</AdminLayout>
