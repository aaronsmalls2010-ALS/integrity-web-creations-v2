---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSchedule } from '../../../lib/db/recurring';
import { listClients } from '../../../lib/db/clients';
import { centsToDollars } from '../../../lib/money';
const s: any = await getSchedule(Astro.cookies, Astro.params.id!);
const clients = await listClients(Astro.cookies);
const id = s.id as string;
---
<AdminLayout title={`Edit: ${s.name}`}>
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-[#e6edf5]">Edit recurring schedule</h1>
    <button id="deactivate" class="btn-ghost text-sm" style="color:#ff6b6b">Deactivate</button>
  </div>
  <form id="f" class="mt-6 max-w-3xl space-y-4" data-id={id} data-lines={JSON.stringify(s.line_items ?? [])}>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="lbl" for="client_id">Client *</label>
        <select id="client_id" name="client_id" required class="input">
          <option value="">Select client…</option>
          {clients.map((c) => <option value={c.id} selected={c.id === s.client_id}>{c.name}</option>)}
        </select>
      </div>
      <div>
        <label class="lbl" for="name">Schedule name *</label>
        <input id="name" name="name" placeholder="e.g. Monthly Hosting" required class="input" value={s.name} />
      </div>
      <div>
        <label class="lbl" for="interval">Interval</label>
        <select id="interval" name="interval" class="input">
          <option value="monthly" selected={s.interval === 'monthly'}>Monthly</option>
          <option value="quarterly" selected={s.interval === 'quarterly'}>Quarterly</option>
          <option value="annual" selected={s.interval === 'annual'}>Annual</option>
        </select>
      </div>
      <div>
        <label class="lbl" for="interval_count">Every N intervals</label>
        <input id="interval_count" name="interval_count" type="number" min="1" value={s.interval_count} class="input" />
      </div>
      <div>
        <label class="lbl" for="next_run_date">Next run date *</label>
        <input id="next_run_date" name="next_run_date" type="date" required class="input" value={s.next_run_date} />
      </div>
      <div class="flex flex-col gap-2 justify-end pb-1">
        <label class="flex items-center gap-2 text-sm text-[#9fb3c8] cursor-pointer">
          <input type="checkbox" name="auto_send" checked={s.auto_send} class="rounded" /> Auto-send (else create as draft for review)
        </label>
        <label class="flex items-center gap-2 text-sm text-[#9fb3c8] cursor-pointer">
          <input type="checkbox" name="active" checked={s.active} class="rounded" /> Active
        </label>
      </div>
    </div>
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-[#9fb3c8]">
          <th>Description</th>
          <th class="w-20">Qty</th>
          <th class="w-28">Unit $</th>
          <th class="w-12">Tax</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="lines"></tbody>
    </table>
    <button type="button" id="addLine" class="btn-ghost text-sm px-3 py-1">+ Line</button>
    <p id="err" class="hidden text-sm text-[#ff6b6b]" role="alert"></p>
    <button type="submit" class="btn-primary">Save changes</button>
  </form>
  <script>
    import { dollarsToCents, centsToDollars } from '../../../lib/money';
    const formEl = document.getElementById('f') as HTMLFormElement;
    const linesEl = document.getElementById('lines')!;
    const scheduleId = formEl.dataset.id!;
    const existingLines: any[] = JSON.parse(formEl.dataset.lines || '[]');

    function addRow(desc = '', price = '', tax = false, qty = 1) {
      const tr = document.createElement('tr');
      tr.className = 'border-t border-white/10';
      tr.innerHTML = `<td><input class="desc w-full rounded border p-1" value="${desc.replace(/"/g, '&quot;')}"/></td><td><input class="qty w-full rounded border p-1" type="number" step="0.01" value="${qty}"/></td><td><input class="unit w-full rounded border p-1" value="${price}"/></td><td class="text-center"><input class="tax" type="checkbox" ${tax ? 'checked' : ''}/></td><td><button type="button" class="rm text-red-600">×</button></td>`;
      linesEl.appendChild(tr);
      tr.querySelector('.rm')!.addEventListener('click', () => tr.remove());
    }

    if (existingLines.length > 0) {
      for (const l of existingLines) {
        addRow(l.description ?? '', centsToDollars(l.unit_price_cents ?? 0), l.taxable ?? false, l.quantity ?? 1);
      }
    } else {
      addRow();
    }

    document.getElementById('addLine')!.addEventListener('click', () => addRow());

    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = form.querySelector('button[type=submit],button:not([type])') as HTMLButtonElement;
      const prevText = btn.textContent!;
      btn.disabled = true; btn.textContent = 'Saving…';
      const line_items = Array.from(linesEl.querySelectorAll('tr')).map((tr) => ({
        description: (tr.querySelector('.desc') as HTMLInputElement).value,
        quantity: Number((tr.querySelector('.qty') as HTMLInputElement).value || '0'),
        unit_price_cents: (() => { try { return dollarsToCents((tr.querySelector('.unit') as HTMLInputElement).value || '0'); } catch { return 0; } })(),
        taxable: (tr.querySelector('.tax') as HTMLInputElement).checked,
      })).filter((l) => l.description.trim() !== '');
      const err = document.getElementById('err')!;
      if (line_items.length === 0) { err.textContent = 'Add at least one line item.'; err.classList.remove('hidden'); btn.disabled = false; btn.textContent = prevText; return; }
      const body = {
        client_id: (form.elements.namedItem('client_id') as HTMLSelectElement).value,
        name: (form.elements.namedItem('name') as HTMLInputElement).value,
        interval: (form.elements.namedItem('interval') as HTMLSelectElement).value,
        interval_count: Number((form.elements.namedItem('interval_count') as HTMLInputElement).value || '1'),
        next_run_date: (form.elements.namedItem('next_run_date') as HTMLInputElement).value,
        auto_send: (form.elements.namedItem('auto_send') as HTMLInputElement).checked,
        active: (form.elements.namedItem('active') as HTMLInputElement).checked,
        line_items,
      };
      const res = await fetch(`/api/admin/recurring/${scheduleId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      const j = await res.json();
      if (res.ok) location.reload();
      else { err.textContent = j.error; err.classList.remove('hidden'); btn.disabled = false; btn.textContent = prevText; }
    });

    document.getElementById('deactivate')!.addEventListener('click', async () => {
      if (!confirm('Deactivate this schedule?')) return;
      const res = await fetch(`/api/admin/recurring/${scheduleId}`, { method: 'DELETE' });
      if (res.ok) window.location.href = '/admin/recurring';
      else { const j = await res.json(); alert(j.error ?? 'Error'); }
    });
  </script>
</AdminLayout>
