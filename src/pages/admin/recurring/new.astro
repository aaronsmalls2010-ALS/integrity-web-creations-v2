---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listClients } from '../../../lib/db/clients';
const clients = await listClients(Astro.cookies);
---
<AdminLayout title="New Recurring Schedule">
  <h1 class="text-2xl font-bold">New recurring schedule</h1>
  <form id="f" class="mt-6 max-w-3xl space-y-4">
    <div class="grid grid-cols-2 gap-3">
      <select name="client_id" required class="rounded border p-2"><option value="">Select client…</option>{clients.map((c) => <option value={c.id}>{c.name}</option>)}</select>
      <input name="name" placeholder="Name (e.g. Monthly Hosting)" required class="rounded border p-2" />
      <select name="interval" class="rounded border p-2"><option value="monthly">Monthly</option><option value="quarterly">Quarterly</option><option value="annual">Annual</option></select>
      <input name="interval_count" type="number" min="1" value="1" class="rounded border p-2" />
      <label class="text-sm">Next run date<input name="next_run_date" type="date" required class="mt-1 w-full rounded border p-2" /></label>
      <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="auto_send" /> Auto-send (else create as draft for review)</label>
    </div>
    <table class="w-full text-sm"><thead><tr class="text-left text-slate-500"><th>Description</th><th class="w-20">Qty</th><th class="w-28">Unit $</th><th class="w-12">Tax</th><th></th></tr></thead><tbody id="lines"></tbody></table>
    <button type="button" id="addLine" class="rounded bg-slate-200 px-3 py-1 text-sm">+ Line</button>
    <p id="err" class="hidden text-sm text-red-600"></p>
    <button class="block rounded bg-blue-700 px-4 py-2 font-semibold text-white">Save schedule</button>
  </form>
  <script>
    import { dollarsToCents } from '../../../lib/money';
    const linesEl = document.getElementById('lines')!;
    function addRow(desc = '', price = '', tax = false, qty = 1) {
      const tr = document.createElement('tr');
      tr.className = 'border-t';
      tr.innerHTML = `<td><input class="desc w-full rounded border p-1" value="${desc.replace(/"/g, '&quot;')}"/></td><td><input class="qty w-full rounded border p-1" type="number" step="0.01" value="${qty}"/></td><td><input class="unit w-full rounded border p-1" value="${price}"/></td><td class="text-center"><input class="tax" type="checkbox" ${tax ? 'checked' : ''}/></td><td><button type="button" class="rm text-red-600">×</button></td>`;
      linesEl.appendChild(tr);
      tr.querySelector('.rm')!.addEventListener('click', () => tr.remove());
    }
    document.getElementById('addLine')!.addEventListener('click', () => addRow());
    addRow();
    document.getElementById('f')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const line_items = Array.from(linesEl.querySelectorAll('tr')).map((tr) => ({
        description: (tr.querySelector('.desc') as HTMLInputElement).value,
        quantity: Number((tr.querySelector('.qty') as HTMLInputElement).value || '0'),
        unit_price_cents: (() => { try { return dollarsToCents((tr.querySelector('.unit') as HTMLInputElement).value || '0'); } catch { return 0; } })(),
        taxable: (tr.querySelector('.tax') as HTMLInputElement).checked,
      })).filter((l) => l.description.trim() !== '');
      const err = document.getElementById('err')!;
      if (line_items.length === 0) { err.textContent = 'Add at least one line item.'; err.classList.remove('hidden'); return; }
      const body = {
        client_id: (form.elements.namedItem('client_id') as HTMLSelectElement).value,
        name: (form.elements.namedItem('name') as HTMLInputElement).value,
        interval: (form.elements.namedItem('interval') as HTMLSelectElement).value,
        interval_count: Number((form.elements.namedItem('interval_count') as HTMLInputElement).value || '1'),
        next_run_date: (form.elements.namedItem('next_run_date') as HTMLInputElement).value,
        auto_send: (form.elements.namedItem('auto_send') as HTMLInputElement).checked,
        active: true,
        line_items,
      };
      const res = await fetch('/api/admin/recurring', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      const j = await res.json();
      if (res.ok) window.location.href = '/admin/recurring';
      else { err.textContent = j.error; err.classList.remove('hidden'); }
    });
  </script>
</AdminLayout>
