---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Contact — Integrity Web Creations" description="Start a project, ask a question, or just say hello. Reach A. Smalls directly — no forms, no chatbots, no runaround.">
  <Nav />
  <main>
    <!-- Page hero -->
    <section class="relative pt-40 pb-20 bg-bg overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/3 right-1/3 w-[600px] h-[600px] rounded-full bg-cyan/[0.015] blur-[120px]"></div>
      </div>
      <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
        <span class="reveal-up text-[10px] font-medium tracking-[0.4em] uppercase text-cyan/60 block mb-4">Get in Touch</span>
        <h1 class="reveal-up font-display font-bold text-white mb-6" style="font-size:clamp(36px,5vw,64px);">
          Let&rsquo;s <span class="text-metallic-bright">Talk</span>
        </h1>
        <p class="reveal-up text-muted text-lg leading-relaxed max-w-2xl mx-auto">
          Start a project, ask a question, or just say hello. You&rsquo;ll hear back from A. Smalls directly &mdash; not a chatbot, not a sales team.
        </p>
      </div>
    </section>

    <!-- Contact section -->
    <section class="relative pb-32 bg-bg overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">

          <!-- Left: contact info -->
          <div class="lg:col-span-2">
            <div class="space-y-8">
              <!-- Phone -->
              <div class="reveal-up">
                <h3 class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium mb-3">Call or Text</h3>
                <a href="tel:+18432630072" class="text-white text-lg font-display font-semibold tracking-wider no-underline hover:text-cyan transition-colors">
                  (843) 263-0072
                </a>
              </div>

              <!-- Email -->
              <div class="reveal-up">
                <h3 class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium mb-3">Email</h3>
                <a href="mailto:asmalls@integritywebcreations.com" class="text-white text-sm font-medium no-underline hover:text-cyan transition-colors break-all tracking-wide">
                  asmalls@integritywebcreations.com
                </a>
              </div>

              <!-- Location -->
              <div class="reveal-up">
                <h3 class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium mb-3">Location</h3>
                <p class="text-muted text-sm tracking-wide">Beaufort, South Carolina</p>
                <p class="text-muted/50 text-xs mt-1 tracking-wide">Serving the Southeast &mdash; Beaufort, Savannah, Atlanta & beyond</p>
              </div>

              <!-- Hours -->
              <div class="reveal-up">
                <h3 class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium mb-3">Response Time</h3>
                <p class="text-muted text-sm tracking-wide">Most messages answered same day</p>
                <p class="text-muted/50 text-xs mt-1 tracking-wide">Emergencies? Call directly anytime.</p>
              </div>

              <!-- Tagline -->
              <div class="reveal-up pt-4">
                <p class="text-steel/20 text-[10px] tracking-[0.5em] uppercase font-medium">
                  Design. Function. Integrity.
                </p>
              </div>
            </div>
          </div>

          <!-- Right: contact form -->
          <div class="lg:col-span-3 reveal-right">
            <form id="contact-form" class="glass-card rounded-lg p-8 lg:p-10 space-y-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="contact-name" class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium block mb-2">Name</label>
                  <input
                    type="text"
                    id="contact-name"
                    name="name"
                    required
                    class="w-full bg-bg/50 border border-white/[0.06] text-white text-sm rounded-md px-4 py-3.5 placeholder:text-steel/30 outline-none focus:border-cyan/30 transition-colors tracking-wide"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label for="contact-email" class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium block mb-2">Email</label>
                  <input
                    type="email"
                    id="contact-email"
                    name="email"
                    required
                    class="w-full bg-bg/50 border border-white/[0.06] text-white text-sm rounded-md px-4 py-3.5 placeholder:text-steel/30 outline-none focus:border-cyan/30 transition-colors tracking-wide"
                    placeholder="you@business.com"
                  />
                </div>
              </div>

              <div>
                <label for="contact-phone" class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium block mb-2">Phone (optional)</label>
                <input
                  type="tel"
                  id="contact-phone"
                  name="phone"
                  class="w-full bg-bg/50 border border-white/[0.06] text-white text-sm rounded-md px-4 py-3.5 placeholder:text-steel/30 outline-none focus:border-cyan/30 transition-colors tracking-wide"
                  placeholder="(555) 123-4567"
                />
              </div>

              <div>
                <label for="contact-subject" class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium block mb-2">What can we help with?</label>
                <select
                  id="contact-subject"
                  name="subject"
                  class="w-full bg-bg/50 border border-white/[0.06] text-white text-sm rounded-md px-4 py-3.5 outline-none focus:border-cyan/30 transition-colors tracking-wide appearance-none cursor-pointer"
                >
                  <option value="new-website" class="bg-bg">New Website</option>
                  <option value="redesign" class="bg-bg">Website Redesign</option>
                  <option value="seo" class="bg-bg">SEO / Search Visibility</option>
                  <option value="ecommerce" class="bg-bg">E-Commerce</option>
                  <option value="maintenance" class="bg-bg">Maintenance Plan</option>
                  <option value="branding" class="bg-bg">Brand Identity</option>
                  <option value="other" class="bg-bg">Something Else</option>
                </select>
              </div>

              <div>
                <label for="contact-message" class="text-[10px] text-steel/60 tracking-[0.3em] uppercase font-medium block mb-2">Message</label>
                <textarea
                  id="contact-message"
                  name="message"
                  required
                  rows="5"
                  class="w-full bg-bg/50 border border-white/[0.06] text-white text-sm rounded-md px-4 py-3.5 placeholder:text-steel/30 outline-none focus:border-cyan/30 transition-colors tracking-wide resize-none"
                  placeholder="Tell us about your project, your business, or what you need..."
                ></textarea>
              </div>

              <button
                type="submit"
                class="magnetic-btn w-full border border-white/10 hover:border-cyan/30 text-white font-semibold py-4 text-sm tracking-[0.15em] uppercase transition-all duration-500 hover:shadow-[0_0_30px_rgba(0,229,255,0.12)] bg-gradient-to-r from-white/[0.06] to-white/[0.02] cursor-pointer"
              >
                Send Message
              </button>

              <p id="contact-status" class="text-center text-sm tracking-wide hidden"></p>
            </form>
          </div>

        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form   = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('contact-status') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const btn  = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'Sending...';
    btn.disabled = true;
    status.classList.add('hidden');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name:    data.get('name'),
          email:   data.get('email'),
          phone:   data.get('phone'),
          subject: data.get('subject'),
          message: data.get('message'),
        }),
      });
      if (res.ok) {
        status.textContent = 'Message sent — A. Smalls will be in touch shortly.';
        status.className = 'text-center text-sm tracking-wide text-cyan/70';
        form.reset();
        btn.textContent = 'Sent';
      } else {
        status.textContent = 'Something went wrong. Please call us directly.';
        status.className = 'text-center text-sm tracking-wide text-danger';
        btn.textContent = 'Send Message';
        btn.disabled = false;
      }
    } catch {
      status.textContent = 'Network error. Please call (843) 263-0072.';
      status.className = 'text-center text-sm tracking-wide text-danger';
      btn.textContent = 'Send Message';
      btn.disabled = false;
    }
  });
</script>
