---
export const prerender = false;
import { getInvoiceByToken, markViewed } from '../../lib/db/invoices';
import { formatUSD } from '../../lib/money';
const token = Astro.params.token!;
const inv: any = await getInvoiceByToken(token);
if (!inv || inv.status === 'void') return new Response('Not found', { status: 404 });
await markViewed(token);
const issuer = inv.issuer_snapshot ?? {};
const bill = inv.bill_to_snapshot ?? {};
const justPaid = Astro.url.searchParams.get('paid') === '1';

/* derived totals from lines */
const subtotalCents: number = inv.lines.reduce((s: number, l: any) => s + (l.amount_cents ?? 0), 0);
const discountCents: number = inv.discount_cents ?? 0;
const taxCents: number = inv.tax_cents ?? 0;
const totalCents: number = inv.total_cents ?? (subtotalCents - discountCents + taxCents);

/* issuer contact: app_settings has no phone/website columns, so these are fixed
   (IWC is the only issuer). Email comes from the snapshot's from_email. */
const BIZ_PHONE = '(843) 263-0072';
const BIZ_WEB = 'www.integritywebcreations.com';
const bizEmail = issuer.from_email ?? issuer.reply_to ?? 'asmalls@integritywebcreations.com';
const bizName = issuer.business_name ?? 'Integrity Web Creations';
const paymentText = (issuer.payment_instructions && String(issuer.payment_instructions).trim())
  || `Pay securely online with the button above, or contact us at ${bizEmail} or ${BIZ_PHONE}. Please make checks payable to ${bizName}.`;
const LOGO_URL = 'https://integrity-web-creations-v2-aaron-smalls-projects.vercel.app/invoice-logo.png';
const termsText = (inv.terms && String(inv.terms).trim())
  || 'Payment is due within 21 days of the invoice date (Net 21). Late balances may be subject to a 1.5% monthly service charge. All work is provided under the service agreement between the client and Integrity Web Creations. Please retain this invoice for your records.';
const notesText = inv.notes && String(inv.notes).trim();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>Invoice {inv.invoice_number} — Integrity Web Creations</title>
  <style>
    /* ── Reset & base ─────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', Arial, Helvetica, sans-serif;
      background: #f1f5f9;
      min-height: 100vh;
      padding: 40px 16px 60px;
      color: #0f172a;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    /* ── Invoice card ─────────────────────────────────────────────── */
    .invoice-card {
      background: #ffffff;
      max-width: 720px;
      margin: 0 auto;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10), 0 1px 4px rgba(0,0,0,0.06);
      overflow: hidden;
    }

    /* ── Branded header band ──────────────────────────────────────── */
    .invoice-header {
      background: #000715;
      padding: 24px 36px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .invoice-logo {
      width: 230px;
      max-width: 60vw;
      height: auto;
      display: block;
    }

    .logo-block {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .logo-wordmark {
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -0.5px;
      line-height: 1;
    }
    .logo-wordmark .logo-integrity { color: #00e5ff; }
    .logo-wordmark .logo-wc        { color: #ffffff; }

    .logo-tagline {
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
      margin-top: 3px;
    }

    .issuer-block {
      text-align: right;
    }
    .issuer-block .issuer-name {
      font-size: 15px;
      font-weight: 700;
      color: #ffffff;
      line-height: 1.3;
    }
    .issuer-block address {
      font-style: normal;
      font-size: 12px;
      color: rgba(255,255,255,0.55);
      line-height: 1.6;
      margin-top: 4px;
    }

    /* ── Invoice body ─────────────────────────────────────────────── */
    .invoice-body {
      padding: 32px 36px 36px;
    }

    /* ── Meta row (invoice # + dates) ────────────────────────────── */
    .invoice-meta {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 28px;
      padding-bottom: 24px;
      border-bottom: 1.5px solid #e2e8f0;
    }

    .invoice-title-block .label {
      font-size: 11px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #94a3b8;
      margin-bottom: 4px;
    }
    .invoice-title-block .invoice-number {
      font-size: 26px;
      font-weight: 800;
      color: #000d1a;
      letter-spacing: -0.5px;
    }

    .invoice-dates {
      display: flex;
      gap: 32px;
      flex-wrap: wrap;
    }
    .date-field .date-label {
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #94a3b8;
      margin-bottom: 3px;
    }
    .date-field .date-value {
      font-size: 14px;
      font-weight: 600;
      color: #1e293b;
    }

    /* ── Bill-to block ────────────────────────────────────────────── */
    .bill-to-section {
      margin-bottom: 28px;
    }
    .bill-to-section .section-label {
      font-size: 11px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #94a3b8;
      margin-bottom: 8px;
    }
    .bill-to-section .client-name {
      font-size: 16px;
      font-weight: 700;
      color: #0f172a;
      line-height: 1.3;
    }
    .bill-to-section .client-business {
      font-size: 13px;
      color: #475569;
      margin-top: 2px;
    }
    .bill-to-section address {
      font-style: normal;
      font-size: 13px;
      color: #64748b;
      line-height: 1.7;
      margin-top: 4px;
    }

    /* ── Line-items table ─────────────────────────────────────────── */
    .line-items-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 0;
      font-size: 14px;
    }
    .line-items-table thead tr {
      background: #f8fafc;
      border-top: 1.5px solid #e2e8f0;
      border-bottom: 1.5px solid #e2e8f0;
    }
    .line-items-table thead th {
      padding: 10px 12px;
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #64748b;
      font-weight: 600;
    }
    .line-items-table thead th:first-child { text-align: left; padding-left: 0; }
    .line-items-table thead th:last-child  { text-align: right; padding-right: 0; }
    .line-items-table thead th:not(:first-child):not(:last-child) { text-align: center; }

    .line-items-table tbody tr {
      border-bottom: 1px solid #f1f5f9;
    }
    .line-items-table tbody tr:last-child { border-bottom: none; }
    .line-items-table tbody td {
      padding: 12px 12px;
      color: #1e293b;
      vertical-align: top;
    }
    .line-items-table tbody td:first-child  { text-align: left; padding-left: 0; }
    .line-items-table tbody td:last-child   { text-align: right; padding-right: 0; font-weight: 500; }
    .line-items-table tbody td:nth-child(2),
    .line-items-table tbody td:nth-child(3) { text-align: center; color: #475569; }

    /* ── Totals block ─────────────────────────────────────────────── */
    .totals-section {
      margin-top: 8px;
      border-top: 1.5px solid #e2e8f0;
      padding-top: 16px;
    }
    .totals-table {
      width: 100%;
      max-width: 280px;
      margin-left: auto;
      font-size: 14px;
      border-collapse: collapse;
    }
    .totals-table td {
      padding: 5px 0;
      color: #475569;
    }
    .totals-table td:last-child {
      text-align: right;
      color: #1e293b;
      font-weight: 500;
    }
    .totals-table .total-row td {
      font-size: 17px;
      font-weight: 800;
      color: #000d1a;
      border-top: 1.5px solid #e2e8f0;
      padding-top: 10px;
      margin-top: 6px;
    }
    .totals-table .balance-row td {
      font-size: 15px;
      font-weight: 700;
      color: #0052cc;
      padding-top: 4px;
    }

    /* ── Success / paid banner ────────────────────────────────────── */
    .paid-banner {
      background: #dcfce7;
      color: #15803d;
      border: 1.5px solid #bbf7d0;
      border-radius: 8px;
      padding: 14px 20px;
      font-weight: 600;
      font-size: 15px;
      margin-top: 28px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .paid-banner::before {
      content: '✓';
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      background: #15803d;
      color: #fff;
      border-radius: 50%;
      font-size: 13px;
      font-weight: 800;
      flex-shrink: 0;
    }

    /* ── Pay-now button ───────────────────────────────────────────── */
    .pay-section {
      margin-top: 28px;
      text-align: center;
    }
    .pay-btn {
      display: inline-block;
      background: linear-gradient(135deg, #0052cc, #00bfff);
      color: #ffffff;
      padding: 14px 40px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      font-size: 16px;
      letter-spacing: 0.2px;
      box-shadow: 0 4px 16px rgba(0,82,204,0.30);
      transition: opacity 0.15s ease, box-shadow 0.15s ease;
    }
    .pay-btn:hover {
      opacity: 0.92;
      box-shadow: 0 6px 20px rgba(0,82,204,0.40);
    }

    /* ── Footer: payment instructions + PDF link ──────────────────── */
    .invoice-footer {
      margin-top: 32px;
      padding-top: 20px;
      border-top: 1px solid #e2e8f0;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      flex-wrap: wrap;
      gap: 16px;
    }
    .payment-instructions {
      font-size: 13px;
      color: #64748b;
      line-height: 1.6;
      max-width: 440px;
    }
    .payment-instructions .instructions-label {
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #94a3b8;
      margin-bottom: 4px;
    }

    .pdf-link {
      display: inline-block;
      border: 1.5px solid #cbd5e1;
      color: #475569;
      padding: 8px 20px;
      border-radius: 7px;
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      white-space: nowrap;
      transition: border-color 0.15s, color 0.15s;
    }
    .pdf-link:hover {
      border-color: #94a3b8;
      color: #1e293b;
    }

    /* ── Print styles ─────────────────────────────────────────────── */
    @media print {
      body {
        background: #ffffff;
        padding: 0;
      }
      .invoice-card {
        box-shadow: none;
        border-radius: 0;
        max-width: 100%;
      }
      .pay-section,
      .pdf-link {
        display: none !important;
      }
      .invoice-header {
        /* keep the navy band — print-color-adjust: exact is set */
      }
    }

    /* ── Responsive ───────────────────────────────────────────────── */
    @media (max-width: 520px) {
      .invoice-header { padding: 22px 20px 20px; }
      .invoice-body   { padding: 24px 20px 28px; }
      .invoice-meta   { flex-direction: column; gap: 16px; }
      .invoice-dates  { gap: 20px; }
      .issuer-block   { text-align: left; }
      .invoice-footer { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>
  <div class="invoice-card">

    <!-- Branded header band -->
    <header class="invoice-header">
      <div class="logo-block">
        <img class="invoice-logo" src={LOGO_URL} alt={bizName} />
      </div>
      <div class="issuer-block">
        <div class="issuer-name">{issuer.business_name}</div>
        <address>
          {issuer.address_line1 && <>{issuer.address_line1}<br /></>}
          {issuer.address_line2 && <>{issuer.address_line2}<br /></>}
          {issuer.city && issuer.state && <>{issuer.city}, {issuer.state} {issuer.postal_code}<br /></>}
          {bizEmail}<br />
          {BIZ_PHONE}<br />
          {BIZ_WEB}
        </address>
      </div>
    </header>

    <!-- Invoice body -->
    <div class="invoice-body">

      <!-- Invoice number + dates row -->
      <div class="invoice-meta">
        <div class="invoice-title-block">
          <div class="label">Invoice</div>
          <div class="invoice-number">{inv.invoice_number}</div>
        </div>
        <div class="invoice-dates">
          <div class="date-field">
            <div class="date-label">Date Issued</div>
            <div class="date-value">{inv.issue_date}</div>
          </div>
          <div class="date-field">
            <div class="date-label">Due Date</div>
            <div class="date-value">{inv.due_date}</div>
          </div>
        </div>
      </div>

      <!-- Bill To -->
      <div class="bill-to-section">
        <div class="section-label">Bill To</div>
        <div class="client-name">{bill.name}</div>
        {bill.business_name && <div class="client-business">{bill.business_name}</div>}
        <address>
          {bill.address_line1 && <>{bill.address_line1}<br /></>}
          {bill.address_line2 && <>{bill.address_line2}<br /></>}
          {bill.city && bill.state && <>{bill.city}, {bill.state} {bill.postal_code}<br /></>}
          {bill.email && <>{bill.email}</>}
        </address>
      </div>

      <!-- Line items -->
      <table class="line-items-table">
        <thead>
          <tr>
            <th>Description</th>
            <th>Qty</th>
            <th>Unit Price</th>
            <th>Amount</th>
          </tr>
        </thead>
        <tbody>
          {inv.lines.sort((a: any, b: any) => a.sort_order - b.sort_order).map((l: any) => (
            <tr>
              <td>{l.description}</td>
              <td>{l.quantity}</td>
              <td>{formatUSD(l.unit_price_cents)}</td>
              <td>{formatUSD(l.amount_cents)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <!-- Totals -->
      <div class="totals-section">
        <table class="totals-table">
          <tbody>
            <tr>
              <td>Subtotal</td>
              <td>{formatUSD(subtotalCents)}</td>
            </tr>
            {discountCents > 0 && (
              <tr>
                <td>Discount</td>
                <td>-{formatUSD(discountCents)}</td>
              </tr>
            )}
            {taxCents > 0 && (
              <tr>
                <td>Tax</td>
                <td>{formatUSD(taxCents)}</td>
              </tr>
            )}
            <tr class="total-row">
              <td>Total</td>
              <td>{formatUSD(totalCents)}</td>
            </tr>
            {inv.balance_cents !== totalCents && (
              <tr class="balance-row">
                <td>Balance Due</td>
                <td>{formatUSD(inv.balance_cents)}</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>

      <!-- Paid / success banner -->
      {(justPaid || inv.status === 'paid') && (
        <div class="paid-banner">Payment received — thank you!</div>
      )}

      <!-- Pay now button -->
      {inv.status !== 'paid' && inv.status !== 'void' && inv.balance_cents > 0 && (
        <div class="pay-section">
          <a href={`/i/${token}/pay`} class="pay-btn">Pay {formatUSD(inv.balance_cents)} Now</a>
        </div>
      )}

      <!-- Terms & notes -->
      <div style="margin-top:28px;border-top:1px solid #e2e8f0;padding-top:18px;font-size:13px;color:#64748b;line-height:1.7;max-width:560px">
        <div class="instructions-label">Terms</div>
        <p>{termsText}</p>
        {notesText && (
          <>
            <div class="instructions-label" style="margin-top:14px">Notes</div>
            <p>{notesText}</p>
          </>
        )}
      </div>

      <!-- Footer: payment instructions + PDF -->
      <div class="invoice-footer">
        <div class="payment-instructions">
          <div class="instructions-label">Payment Instructions</div>
          {paymentText}
        </div>
        <a href={`/i/${token}/pdf`} class="pdf-link">Download PDF</a>
      </div>

    </div><!-- /.invoice-body -->
  </div><!-- /.invoice-card -->
</body>
</html>
