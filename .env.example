# Contact form — Bluehost SMTP
# Add these as Environment Variables in your Vercel project dashboard.
# Never commit actual credentials; this file is safe to commit.

SMTP_HOST=mail.integritywebcreations.com
SMTP_PORT=465
SMTP_USER=asmalls@integritywebcreations.com
SMTP_PASS=your_bluehost_email_password_here

# Optional: override the address that receives contact emails
# Defaults to SMTP_USER if not set
# CONTACT_TO=hello@integritywebcreations.com
