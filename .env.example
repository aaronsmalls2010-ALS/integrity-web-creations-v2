# Add these as Environment Variables in your Vercel project dashboard.
# Never commit actual credentials; this file is safe to commit.

# ── IWC CRM (Supabase: umami-analytics project, crm schema) ──────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # Dashboard → Settings → API
ADMIN_ALLOWLIST_EMAIL=asmalls@integritywebcreations.com

# Stripe (TEST mode in dev) — Phase 3
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Cron + transactional email — Phase 3/4
CRON_SECRET=long_random_string
POSTMARK_SERVER_TOKEN=your_postmark_server_token
INVOICE_FROM_EMAIL=billing@integritywebcreations.com
INVOICE_REPLY_TO=asmalls@integritywebcreations.com

# ── Contact form — Bluehost SMTP ─────────────────────────────────────────────
SMTP_HOST=mail.integritywebcreations.com
SMTP_PORT=465
SMTP_USER=asmalls@integritywebcreations.com
SMTP_PASS=your_bluehost_email_password_here

# Optional: override the address that receives contact emails
# Defaults to SMTP_USER if not set
# CONTACT_TO=hello@integritywebcreations.com
